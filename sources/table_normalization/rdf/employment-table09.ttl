@prefix emp: <http://example.org/employment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

emp:EmploymentStatistics a rdfs:Class ;
    rdfs:label "Employment statistics"@en, "Статистика занятости"@ru ;
    rdfs:comment "Annual statistics of employment of the civilian population of the United States, broken down by occupation, gender, and age group"@en, "Ежегодные статистические данные занятости гражданского населения США с детализацией по профессиям, полу и возрастной группе"@ru .

# ==================== Datatype Properties ====================

emp:year a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "The calendar year for which the statistic is reported"@en, "Календарный год, за который приводятся статистические данные"@ru .

emp:occupation a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Occupation"@en, "Профессия"@ru ;
    rdfs:comment "Occupation category"@en, "Категория профессии"@ru .

emp:sex a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Sex"@en, "Пол"@ru ;
    rdfs:comment "Sex category"@en, "Категория пола"@ru .

emp:ageGroup a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Age group"@en, "Возрастная группа"@ru ;
    rdfs:comment "Age group category"@en, "Категория возрастной группы"@ru .

emp:employedNumber a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Number of employed"@en, "Количество занятых"@ru ;
    rdfs:comment "A numerical value representing the number of people employed"@en, "Числовое значение, представляющее количество занятых"@ru .
