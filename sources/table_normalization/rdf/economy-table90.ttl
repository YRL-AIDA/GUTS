@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:DirectLoanPortfolio a rdfs:Class ;
    rdfs:label "Direct loan portfolio"@en, "Портфель прямых кредитов"@ru ;
    rdfs:comment "Direct loan portfolio by repayment plan including outstanding principal and interest balances of direct loan borrowers in repayment, deferment, and forbearance"@en, "Портфель прямых кредитов с планом погашения, включая непогашенные остатки основного долга и процентов заемщиков по прямым кредитам, находящихся в процессе погашения, отсрочки и приостановки платежей"@ru .

# ==================== Datatype Properties ====================

eco:year a rdf:Property ;
    rdfs:domain eco:DirectLoanPortfolio ;
    rdfs:range xsd:gYear ;
    rdfs:label "year"@en, "Год"@ru ;
    rdfs:comment "Federal fiscal year for the reporting period"@en, "Федеральный финансовый год отчетного периода"@ru .

eco:quarter a rdf:Property ;
    rdfs:domain eco:DirectLoanPortfolio ;
    rdfs:range xsd:string ;
    rdfs:label "Quarter"@en, "Квартал"@ru ;
    rdfs:comment "Quarter within the fiscal year (1–4) for the reporting period"@en, "Квартал в рамках финансового года (1–4) для отчетного периода"@ru .

eco:repaymentPlan a rdf:Property ;
    rdfs:domain eco:DirectLoanPortfolio ;
    rdfs:range xsd:string ;
    rdfs:label "Repayment plan"@en, "План погашения"@ru ;
    rdfs:comment "Type (level) of repayment plan"@en, "Тип (уровень) плана погашения"@ru .

eco:dollarsOutstanding a rdf:Property ;
    rdfs:domain eco:DirectLoanPortfolio ;
    rdfs:range xsd:decimal ;
    rdfs:label "Dollars outstanding"@en, "Сумма непогашенных платежей"@ru ;
    rdfs:comment "Total outstanding principal and interest in billions of US dollars"@en, "Общий непогашенный остаток основного долга и процентов в миллиардах долларов США"@ru .

eco:recipients a rdf:Property ;
    rdfs:domain eco:DirectLoanPortfolio ;
    rdfs:range xsd:decimal ;
    rdfs:label "Recipients"@en, "Получатели"@ru ;
    rdfs:comment "Number of borrowers in millions of individuals"@en, "Количество заемщиков в миллионах"@ru .
