@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:PurchaseData a rdfs:Class ;
    rdfs:label "Purchase data"@en, "Данные о покупках"@ru ;
    rdfs:comment "A joint expense observation representing the purchased item with amounts attributed to different payers"@en, "Наблюдение совместного расхода, представляющее приобретенный товар с суммами, отнесенными к различным плательщикам"@ru .

eco:PurchaseAggregation a rdfs:Class ;
    rdfs:label "Aggregation of purchases"@en, "Агрегация покупок"@ru ;
    rdfs:comment "Aggregation of purchases made by all customers"@en, "Агрегация покупок, сделанных всеми покупателями"@ru .

# ==================== Datatype Properties ====================

eco:productCategory a rdf:Property ;
    rdfs:domain eco:PurchaseData ;
    rdfs:range xsd:string ;
    rdfs:label "Product category"@en, "Категория продукта"@ru ;
    rdfs:comment "The product category to which the item belongs"@en, "Категория товара, к которой относится позиция"@ru .

eco:productName a rdf:Property ;
    rdfs:domain eco:PurchaseData ;
    rdfs:range xsd:string ;
    rdfs:label "Product name"@en, "Название продукта"@ru ;
    rdfs:comment "The name or description of the purchased item"@en, "Название или описание приобретенного товара"@ru .

eco:customer a rdf:Property ;
    rdfs:domain eco:PurchaseData ;
    rdfs:range xsd:string ;
    rdfs:label "Customer"@en, "Покупатель"@ru ;
    rdfs:comment "The name of the customer who purchases the product"@en, "Имя покупателя, который приобретает товар"@ru .

eco:amount a rdf:Property ;
    rdfs:domain eco:PurchaseData ;
    rdfs:range xsd:decimal ;
    rdfs:label "Amount"@en, "Сумма"@ru ;
    rdfs:comment "The amount paid by the customer in US dollars"@en, "Сумма, уплаченная покупателем в долларах США"@ru .

eco:productCategory a rdf:Property ;
    rdfs:domain eco:PurchaseAggregation ;
    rdfs:range xsd:string ;
    rdfs:label "Product category"@en, "Категория продукта"@ru ;
    rdfs:comment "The product category to which the item belongs"@en, "Категория товара, к которой относится позиция"@ru .

eco:productName a rdf:Property ;
    rdfs:domain eco:PurchaseAggregation ;
    rdfs:range xsd:string ;
    rdfs:label "Product name"@en, "Название продукта"@ru ;
    rdfs:comment "The name or description of the purchased item"@en, "Название или описание приобретенного товара"@ru .

eco:totalAmount a rdf:Property ;
    rdfs:domain eco:PurchaseAggregation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Total amount"@en, "Общая сумма"@ru ;
    rdfs:comment "Total amount paid by all customers in US dollars"@en, "Общая сумма, уплаченная всеми покупателями в долларах США"@ru .
