@prefix geo: <http://example.org/geography#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

geo:GeologyQSystemObservation a rdfs:Class ;
    rdfs:label "Geology Q-system observation"@en, "Наблюдение Q-системы в геологии"@ru ;
    rdfs:comment "A single data point representing rock mass quality assessment using Barton's Q-system for a specific mine, geological lens, and drive type"@en, "Отдельная точка данных, представляющая оценку качества горной массы по системе Бартон (Q-система) для конкретной шахты, геологической линзы и типа выработки"@ru .

# ==================== Datatype Properties ====================

geo:date a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:date ;
    rdfs:label "Date"@en, "Дата"@ru ;
    rdfs:comment "The date when the geological observation or measurement was performed"@en, "Дата проведения геологического наблюдения или измерения"@ru .

geo:mine a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Mine"@en, "Шахта"@ru ;
    rdfs:comment "Identifier or code of the mine or deposit where the observation was made"@en, "Идентификатор или код шахты либо месторождения, где проводилось наблюдение"@ru .

geo:lens a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Lens"@en, "Линза"@ru ;
    rdfs:comment "Name or code of the geological lens or zone within the mine"@en, "Название или код геологической линзы или зоны в пределах шахты"@ru .

geo:driveType a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Drive type"@en, "Тип выработки"@ru ;
    rdfs:comment "Code identifying the specific drive, tunnel section, or sampling point"@en, "Код, идентифицирующий конкретную выработку, секцию тоннеля или точку отбора проб"@ru .

geo:generalSource a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:integer ;
    rdfs:label "General source"@en, "Общий источник"@ru ;
    rdfs:comment "Numeric identifier of the source section or reference point for the observation"@en, "Числовой идентификатор секции источника или опорной точки для наблюдения"@ru .

geo:xCoordinate a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "X coordinate"@en, "Координата X"@ru ;
    rdfs:comment "Eastings coordinate (X) of the observation point in the local coordinate system"@en, "Координата по оси X (восточная) точки наблюдения в локальной системе координат"@ru .

geo:yCoordinate a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Y coordinate"@en, "Координата Y"@ru ;
    rdfs:comment "Northings coordinate (Y) of the observation point in the local coordinate system"@en, "Координата по оси Y (северная) точки наблюдения в локальной системе координат"@ru .

geo:zCoordinate a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Z coordinate"@en, "Координата Z"@ru ;
    rdfs:comment "Elevation coordinate (Z) of the observation point"@en, "Координата по высоте (Z) точки наблюдения"@ru .

geo:stratigraphy a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Stratigraphy"@en, "Стратиграфия"@ru ;
    rdfs:comment "Code of the stratigraphic unit or geological formation at the observation point"@en, "Код стратиграфической единицы или геологической формации в точке наблюдения"@ru .

geo:lithology a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Lithology"@en, "Литология"@ru ;
    rdfs:comment "Code of the lithology or rock type at the observation point"@en, "Код литологии или типа горной породы в точке наблюдения"@ru .

geo:rqd a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Rock Quality Designation (RDQ)"@en, "Показатель качества горной породы"@ru ;
    rdfs:comment "Rock Quality Designation: percentage of intact core pieces longer than 10 cm in the total core length"@en, "Показатель качества горной породы: процент целых кусков керна длиной более 10 см от общей длины керна"@ru .

geo:jn a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Joint set number (Jn)"@en, "Число наборов трещин"@ru ;
    rdfs:comment "Joint set number: parameter representing the number of joint sets in the rock mass"@en, "Число наборов трещин: параметр, представляющий количество наборов трещин в горной массе"@ru .

geo:jr a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Joint roughness number (Jr)"@en, "Шероховатость трещин"@ru ;
    rdfs:comment "Joint roughness number: parameter representing the roughness of the most unfavorable joint"@en, "Шероховатость трещин: параметр, представляющий шероховатость наиболее неблагоприятной трещины"@ru .

geo:ja a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Joint alteration number (Ja)"@en, "Измененность трещин"@ru ;
    rdfs:comment "Joint alteration number: parameter representing the degree of alteration or filling of joints"@en, "Измененность трещин: параметр, представляющий степень изменения или заполнения трещин"@ru .

geo:jw a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Joint water reduction factor (Jw)"@en, "Водный редукционный коэффициент"@ru ;
    rdfs:comment "Joint water reduction factor: parameter accounting for water inflow or pressure in joints"@en, "Водный редукционный коэффициент: параметр, учитывающий приток воды или давление в трещинах"@ru .

geo:srf a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Stress reduction factor (SRF)"@en, "Коэффициент редукции напряжений"@ru ;
    rdfs:comment "Stress reduction factor: parameter accounting for stress conditions, loosening, or squeezing in the rock mass"@en, "Коэффициент редукции напряжений: параметр, учитывающий условия напряжений, разуплотнение или выдавливание в горной массе"@ru .

geo:qPrime a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Intermediate Q-value"@en, "Промежуточное значение Q"@ru ;
    rdfs:comment "Intermediate Q-value calculated as (RQD/Jn) × (Jr/Ja) × (Jw/SRF) before stress adjustment"@en, "Промежуточное значение Q, рассчитанное как (RQD/Jn) × (Jr/Ja) × (Jw/SRF) до корректировки по напряжениям"@ru .

geo:qValue a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Q-value"@en, "Значение Q"@ru ;
    rdfs:comment "Final Barton's Q index value representing overall rock mass quality"@en, "Итоговое значение индекса Q по Бартон, представляющее общее качество горной массы"@ru .

geo:rating a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Rating"@en, "Оценка"@ru ;
    rdfs:comment "Qualitative rock mass rating based on Q-value"@en, "Качественная оценка горной массы на основе значения Q"@ru .

geo:perimeterCondition a rdf:Property ;
    rdfs:domain geo:GeologyQSystemObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Perimeter condition"@en, "Состояние контура"@ru ;
    rdfs:comment "Qualitative assessment of the excavation perimeter condition"@en, "Качественная оценка состояния контура выработки"@ru .
