@prefix env: <http://example.org/environment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

env:AnimalObservation a rdfs:Class ;
    rdfs:label "Animal observation"@en, "Наблюдение за животным"@ru ;
    rdfs:comment "Animal observation in the open field test, characterized by genotype, experimental group, pharmacological treatment, and behavioral measures related to center dwell time and center entry latency"@en, "Наблюдение за животным в тесте открытого поля, охарактеризованное генотипом, экспериментальной группой, фармакологической обработкой и поведенческими измерениями, связанными со временем пребывания в центре и латентностью входа в центр"@ru .

env:AggregatedObservationInformation a rdfs:Class ;
    rdfs:label "Aggregated observation information"@en, "Агрегированная информация по наблюдениям"@ru ;
    rdfs:comment "Aggregated observation information for all animals in experiments"@en, "Агрегированная информация по наблюдениям для всех животных в экспериментах"@ru .

# ==================== Datatype Properties ====================

env:animal a rdf:Property ;
    rdfs:domain env:AnimalObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Animal"@en, "Животное"@ru ;
    rdfs:comment "Unique identifier of an animal"@en, "Уникальный идентификатор животного"@ru .

env:genotype a rdf:Property ;
    rdfs:domain env:AnimalObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Genotype"@en, "Генотип"@ru ;
    rdfs:comment "Genotype of an animal"@en, "Генотип животного"@ru .

env:group a rdf:Property ;
    rdfs:domain env:AnimalObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Group"@en, "Группа"@ru ;
    rdfs:comment "Experimental group to which the animal belongs"@en, "Экспериментальная группа, к которой принадлежит животное"@ru .

env:treatment a rdf:Property ;
    rdfs:domain env:AnimalObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Treatment"@en, "Обработка"@ru ;
    rdfs:comment "Pharmacological treatment applied to the animal"@en, "Фармакологическая обработка, примененная к животному"@ru .

env:timeCentre a rdf:Property ;
    rdfs:domain env:AnimalObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Time centre"@en, "Время в центре"@ru ;
    rdfs:comment "Duration the animal spent in the central area of the open field arena, measured in seconds"@en, "Продолжительность пребывания животного в центральной части арены открытого поля, в секундах"@ru .

env:latencyCentre a rdf:Property ;
    rdfs:domain env:AnimalObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Latency centre"@en, "Латентность центра"@ru ;
    rdfs:comment "Latency period before the animal first entered the central area of the open field arena, measured in seconds"@en, "Латентный период до первого входа животного в центральную часть арены открытого поля, в секундах"@ru .






env:genotype a rdf:Property ;
    rdfs:domain env:AggregatedObservationInformation ;
    rdfs:range xsd:string ;
    rdfs:label "Genotype"@en, "Генотип"@ru ;
    rdfs:comment "Genotype of an animal"@en, "Генотип животного"@ru .

env:group a rdf:Property ;
    rdfs:domain env:AggregatedObservationInformation ;
    rdfs:range xsd:string ;
    rdfs:label "Group"@en, "Группа"@ru ;
    rdfs:comment "Experimental group to which the animal belongs"@en, "Экспериментальная группа, к которой принадлежит животное"@ru .

env:treatment a rdf:Property ;
    rdfs:domain env:AggregatedObservationInformation ;
    rdfs:range xsd:string ;
    rdfs:label "Treatment"@en, "Обработка"@ru ;
    rdfs:comment "Pharmacological treatment applied to the animal"@en, "Фармакологическая обработка, примененная к животному"@ru .

env:averageTimeCentre a rdf:Property ;
    rdfs:domain env:AggregatedObservationInformation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Average time centre"@en, "Среднее время в центре"@ru ;
    rdfs:comment "Average duration the animal spent in the central area of the open field arena, measured in seconds"@en, "Средняя продолжительность пребывания животного в центральной части арены открытого поля, в секундах"@ru .

env:timeCentreStandardDeviation a rdf:Property ;
    rdfs:domain env:AggregatedObservationInformation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Standard deviation of time centre"@en, "Стандартное отклонение времени в центре"@ru ;
    rdfs:comment "Standard deviation of of duration the animal spent in the central area of the open field arena, measured in seconds"@en, "Стандартное отклонение продолжительности пребывания животного в центральной части арены открытого поля, в секундах"@ru .

env:timeCentreStatisticalError a rdf:Property ;
    rdfs:domain env:AggregatedObservationInformation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Statistical error of time centre"@en, "Статистическая ошибка времени в центре"@ru ;
    rdfs:comment "Statistical error in duration the animal spent in the central area of the open field arena, measured in seconds"@en, "Статистическая ошибка при продолжительности пребывания животного в центральной части арены открытого поля, в секундах"@ru .

env:averageLatencyCentre a rdf:Property ;
    rdfs:domain env:AggregatedObservationInformation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Average latency centre"@en, "Средняя латентность центра"@ru ;
    rdfs:comment "Average latency period before the animal first entered the central area of the open field arena, measured in seconds"@en, "Средний латентный период до первого входа животного в центральную часть арены открытого поля, в секундах"@ru .

env:latencyCentreStandardDeviation a rdf:Property ;
    rdfs:domain env:AggregatedObservationInformation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Standard deviation of latency centre"@en, "Стандартное отклонение латентности центра"@ru ;
    rdfs:comment "Standard deviation of latency period before the animal first entered the central area of the open field arena, measured in seconds"@en, "Стандартное отклонение латентного периода до первого входа животного в центральную часть арены открытого поля, в секундах"@ru .

env:latencyCentreStatisticalError a rdf:Property ;
    rdfs:domain env:AggregatedObservationInformation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Statistical error of latency centre"@en, "Статистическая ошибка латентности центра"@ru ;
    rdfs:comment "Statistical error in latency period before the animal first entered the central area of the open field arena, measured in seconds"@en, "Статистическая ошибка в латентном периоде до первого входа животного в центральную часть арены открытого поля, в секундах"@ru .
