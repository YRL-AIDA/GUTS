@prefix scn: <http://example.org/science#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

scn:TransformedCloneSizeDistribution a rdfs:Class ;
    rdfs:label "Transformed clone size distribution"@en , "Распределение размеров трансформированных клонов"@ru ;
    rdfs:comment "Cumulative distribution of transformed (tumorigenic) luminal clone sizes in Brca1;Trp53 confetti mouse model at a specific time point"@en , "Кумулятивное распределение размеров трансформированных (опухолевых) люминальных клонов в модели мыши Brca1;Trp53 confetti на заданной временной точке"@ru .

# ==================== Datatype Properties ====================

scn:timePoint a rdf:Property ;
    rdfs:domain scn:TransformedCloneSizeDistribution ;
    rdfs:range xsd:integer ;
    rdfs:label "Time point"@en , "Временная точка"@ru ;
    rdfs:comment "Observation time point in days post-induction (14, 64, 120 or 225 days)"@en , "Временная точка наблюдения в днях после индукции (14, 64, 120 или 225 дней)"@ru .

scn:cloneSize a rdf:Property ;
    rdfs:domain scn:TransformedCloneSizeDistribution ;
    rdfs:range xsd:decimal ;
    rdfs:label "Clone size"@en , "Размер клона"@ru ;
    rdfs:comment "Normalized size of transformed clone (dimensionless quantity, ratio to mean size)"@en , "Нормализованный размер трансформированного клона (безразмерная величина, отношение к среднему размеру)"@ru .

scn:cumulativeProbability a rdf:Property ;
    rdfs:domain scn:TransformedCloneSizeDistribution ;
    rdfs:range xsd:decimal ;
    rdfs:label "Cumulative probability"@en , "Кумулятивная вероятность"@ru ;
    rdfs:comment "Cumulative probability (proportion of transformed clones with size ≤ given value)"@en , "Кумулятивная вероятность (доля трансформированных клонов с размером ≤ данного значения)"@ru .
