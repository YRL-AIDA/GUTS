@prefix hl: <http://example.org/health#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

hl:HealthGraduationObservation a rdfs:Class ;
    rdfs:label "Health graduation observation"@en, "Наблюдение за выпуском медработников"@ru ;
    rdfs:comment "A record for representing the proportion of health profession graduates per 100000 inhabitants for a specific area, profession, and year"@en, "Запись, представляющая долю выпускников медицинских специальностей на 100000 жителей для конкретного региона, профессии и года"@ru .

# ==================== Datatype Properties ====================

hl:timePeriod a rdf:Property ;
    rdfs:domain hl:HealthGraduationObservation ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "Calendar year of observation"@en, "Календарный год наблюдения"@ru .

hl:referenceArea a rdf:Property ;
    rdfs:domain hl:HealthGraduationObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Country"@en, "Страна"@ru ;
    rdfs:comment "Country name"@en, "Наименование страны"@ru .

hl:typeArea a rdf:Property ;
    rdfs:domain hl:HealthGraduationObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Type of country's economy"@en, "Тип экономики страны"@ru ;
    rdfs:comment "Economies of countries that are members of the Organisation for Economic Co-operation and Development (OECD)"@en, "Экономики стран, входящие в организацию экономического сотрудничества и развития (ОЭСР)"@ru .

hl:healthProfession a rdf:Property ;
    rdfs:domain hl:HealthGraduationObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Health profession"@en, "Медицинская профессия"@ru ;
    rdfs:comment "Category of medical professionals"@en, "Категория медицинских работников"@ru .

hl:physicianProportion a rdf:Property ;
    rdfs:domain hl:HealthGraduationObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Physician proportion"@en, "Доля врачей"@ru ;
    rdfs:comment "The proportion of health graduates per 100000 inhabitants"@en, "Доля выпускников медицинских вузов на 100000 жителей"@ru .
