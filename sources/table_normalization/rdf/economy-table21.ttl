@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:DebtReliefObservation a rdfs:Class ;
    rdfs:label "Debt relief observation"@en, "Наблюдение за списанием долгов"@ru ;
    rdfs:comment "Debt relief order rates per 10,000 adults by location, England and Wales, 2011 to 2021"@en, "Показатели списания долгов на 10 000 взрослых по месту жительства, Англия и Уэльс, 2011–2021 гг."@ru .

# ==================== Datatype Properties ====================

eco:year a rdf:Property ;
    rdfs:domain eco:DebtReliefObservation ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "Calendar year of observation"@en, "Календарный год наблюдения"@ru .

eco:code a rdf:Property ;
    rdfs:domain eco:DebtReliefObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Code"@en, "Код"@ru ;
    rdfs:comment "The geographic code of location"@en, "Географический код местоположения"@ru .

eco:location a rdf:Property ;
    rdfs:domain eco:DebtReliefObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Location"@en, "Местоположение"@ru ;
    rdfs:comment "The name of the geographic are"@en, "Название географической области"@ru .

eco:geography a rdf:Property ;
    rdfs:domain eco:DebtReliefObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Geography"@en, "География"@ru ;
    rdfs:comment "The type of geographic area"@en, "Тип географической области"@ru .

eco:debtReliefOrderRate a rdf:Property ;
    rdfs:domain eco:DebtReliefObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Rate of debt relief orders"@en, "Уровень распоряжений о списании долгов"@ru ;
    rdfs:comment "The rate of debt relief orders over a given period of time as a percentage"@en, "Уровень распоряжений о списании долгов за определенный период времени в процентах"@ru .
