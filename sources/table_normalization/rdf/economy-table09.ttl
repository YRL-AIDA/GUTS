@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:BankruptcyPetitionObservation a rdfs:Class ;
    rdfs:label "Bankruptcy petition observation"@en, "Наблюдение заявлений о банкротстве"@ru ;
    rdfs:comment "The observation of bankruptcies by petition type in England and Wales, not seasonally adjusted, 1 January 2012 to 30 June 2022"@en, "Наблюдение за количеством случаев банкротства по типам заявлений в Англии и Уэльсе без учета сезонных колебаний, с 1 января 2012 г. по 30 июня 2022 г."@ru .

# ==================== Datatype Properties ====================

eco:year a rdf:Property ;
    rdfs:domain eco:BankruptcyPetitionObservation ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "Calendar year of observation"@en, "Календарный год наблюдения"@ru .

eco:quarter a rdf:Property ;
    rdfs:domain eco:BankruptcyPetitionObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Quarter"@en, "Квартал"@ru ;
    rdfs:comment "The time period: Q1, Q2, Q3, Q4 for quarterly data"@en, "Временной период: Q1, Q2, Q3, Q4 для квартальных данных"@ru .

eco:petitionType a rdf:Property ;
    rdfs:domain eco:BankruptcyPetitionObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Petition type"@en, "Тип заявления"@ru ;
    rdfs:comment "The type of bankruptcy petition"@en, "Тип заявления о банкротстве"@ru .

eco:petitionNumber a rdf:Property ;
    rdfs:domain eco:BankruptcyPetitionObservation ;
    rdfs:range xsd:integer ;
    rdfs:label "Number of petitions"@en, "Количество заявлений"@ru ;
    rdfs:comment "The number of bankruptcy petitions for a given time period"@en, "Количество заявлений банкротств для данного временного периода"@ru .

eco:percentageChange a rdf:Property ;
    rdfs:domain eco:BankruptcyPetitionObservation ;
    rdfs:range xsd:integer ;
    rdfs:label "Percentage change"@en, "Процентное изменение"@ru ;
    rdfs:comment "Percentage change for the latest quarter compared to the previous one"@en, "Процентное изменение за последний квартал по сравнению с предыдущим"@ru .

eco:dataStatus a rdf:Property ;
    rdfs:domain eco:BankruptcyPetitionObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Data status"@en, "Статус данных"@ru ;
    rdfs:comment "The quality flag of the data (not applicable, revised, provisional, or empty)"@en, "Флаг качества данных (неприменимые, пересмотренные, предварительные или пустое значение)"@ru .
