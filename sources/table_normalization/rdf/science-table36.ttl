@prefix scn: <http://example.org/science#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

scn:OvariectomyCloneSize a rdfs:Class ;
    rdfs:label "Ovariectomy clone size"@en , "Размер клона овариэктомии"@ru ;
    rdfs:comment "Clone size of mammary gland epithelium in confetti mouse model following ovariectomy (postmenopausal model)"@en , "Размер клона эпителия молочной железы мыши в модели confetti после овариэктомии (постменопаузальная модель)"@ru .

scn:MeasurementAggregation a rdfs:Class ;
    rdfs:label "Measurement aggregation"@en , "Агрегирование измерений"@ru ;
    rdfs:comment "Aggregation of clone size measurements"@en , "Агрегирование результатов измерений размера клона"@ru .

# ==================== Datatype Properties ====================

scn:timePoint a rdf:Property ;
    rdfs:domain scn:OvariectomyCloneSize ;
    rdfs:range xsd:integer ;
    rdfs:label "Time point"@en , "Временная точка"@ru ;
    rdfs:comment "Observation time point in days post-induction (14, 64, 120 or 225 days)"@en , "Временная точка наблюдения в днях после индукции (14, 64, 120 или 225 дней)"@ru .

scn:cloneType a rdf:Property ;
    rdfs:domain scn:OvariectomyCloneSize ;
    rdfs:range xsd:string ;
    rdfs:label "Clone type"@en , "Тип клона"@ru ;
    rdfs:comment "Cell type of clone"@en , "Тип клеток клона"@ru .

scn:cloneSize a rdf:Property ;
    rdfs:domain scn:OvariectomyCloneSize ;
    rdfs:range xsd:integer ;
    rdfs:label "Clone size"@en , "Размер клона"@ru ;
    rdfs:comment "Clone size in arbitrary units (integer)"@en , "Размер клона в условных единицах (целое число)"@ru .

scn:timePoint a rdf:Property ;
    rdfs:domain scn:MeasurementAggregation ;
    rdfs:range xsd:integer ;
    rdfs:label "Time point"@en , "Временная точка"@ru ;
    rdfs:comment "Observation time point in days post-induction (14, 64, 120 or 225 days)"@en , "Временная точка наблюдения в днях после индукции 14, 64, 120 или 225 дней)"@ru .

scn:pooledMice a rdf:Property ;
    rdfs:domain scn:MeasurementAggregation ;
    rdfs:range xsd:integer ;
    rdfs:label "Pooled mice"@en , "Объединенные мыши"@ru ;
    rdfs:comment "Total number of cell clones for pooled mice"@en , "Общее количество клонов клеток для объединенных мышей"@ru .

scn:totalLuminal a rdf:Property ;
    rdfs:domain scn:MeasurementAggregation ;
    rdfs:range xsd:integer ;
    rdfs:label "Total luminal"@en , "Общее количество люминальных"@ru ;
    rdfs:comment "Total number of luminal cell clones"@en , "Общее количество люминальных клеток клонов"@ru .

scn:totalBasal a rdf:Property ;
    rdfs:domain scn:MeasurementAggregation ;
    rdfs:range xsd:integer ;
    rdfs:label "Total basal"@en , "Общее количество базальных"@ru ;
    rdfs:comment "Total number of basal cell clones"@en , "Общее количество базальных клеток клонов"@ru .
