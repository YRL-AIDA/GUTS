@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:WorkLog a rdfs:Class ;
    rdfs:label "Work log"@en, "Журнал работ"@ru ;
    rdfs:comment "Summary information on work operations (orders) for an employee"@en, "Сводная информация по рабочим операциям (заказам) для сотрудника"@ru .

eco:WorkTransaction a rdfs:Class ;
    rdfs:label "Work transaction"@en, "Рабочая транзакция"@ru ;
    rdfs:comment "Information on work operations (orders) for an employee, including service details, quantities, rates, and compensatio"@en, "Информация по рабочим операциям (заказам) для сотрудника, включая детали услуги, количество, ставки и компенсацию"@ru .

# ==================== Object Properties ====================

eco:hasWorkTransaction a rdf:Property ;
    rdfs:domain eco:WorkLog ;
    rdfs:range eco:WorkTransaction ;
    rdfs:label "Work transaction"@en, "Рабочая транзакция"@ru ;
    rdfs:comment "A work log containing work transactions"@en, "Журнал работ содержащий рабочие транзакции"@ru .

# ==================== Datatype Properties ====================

eco:date a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:date ;
    rdfs:label "Date"@en, "Дата"@ru ;
    rdfs:comment "Date of completion of work"@en, "Дата выполнения работы"@ru .

eco:ticketNumber a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:integer ;
    rdfs:label "Ticket number"@en, "Номер заказа"@ru ;
    rdfs:comment "Unique identifier for the work order or job ticket"@en, "Уникальный идентификатор для рабочего задания или заявки на выполнение работ"@ru .

eco:truckNumber a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:string ;
    rdfs:label "Truck number"@en, "Номер грузовика"@ru ;
    rdfs:comment "Identifier of the truck used for the work operation"@en, "Идентификатор грузового автомобиля, использованного для выполнения рабочей операции"@ru .

eco:trailerNumber a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:string ;
    rdfs:label "Trailer number"@en, "Номер прицепа"@ru ;
    rdfs:comment "Identifier of the trailer used for the work operation"@en, "Идентификатор прицепа, использованного для выполнения работ"@ru .

eco:company a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:string ;
    rdfs:label "Company"@en, "Компания"@ru ;
    rdfs:comment "Name of the client company for which the work was performed"@en, "Название компании-заказчика для которой была выполнена работа"@ru .

eco:product a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:string ;
    rdfs:label "Product"@en, "Продукт"@ru ;
    rdfs:comment "Type of service performed"@en, "Вид оказанной услуги"@ru .

eco:quantity a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:integer ;
    rdfs:label "Quantity"@en, "Количество"@ru ;
    rdfs:comment "Volume of work performed, measured in barrels (bbls)"@en, "Объем выполненной работы, измеряемый в баррелях"@ru .

eco:time a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:decimal ;
    rdfs:label "Time"@en, "Время"@ru ;
    rdfs:comment "Duration of work performed, measured in hours"@en, "Продолжительность выполненной работы, измеряемая в часах"@ru .

eco:rate a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:decimal ;
    rdfs:label "Rate"@en, "Ставка"@ru ;
    rdfs:comment "Billing rate for the service"@en, "Тариф на оказание услуги"@ru .

eco:waterCharge a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:decimal ;
    rdfs:label "Water charge"@en, "Плата за воду"@ru ;
    rdfs:comment "Additional charge for water usage associated with the work operation in the base currency"@en, "Дополнительная плата за водопотребление, связанное с выполнением работ, в базовой валюте"@ru .

eco:amountBilled a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:decimal ;
    rdfs:label "Amount billed"@en, "Сумма к оплате"@ru ;
    rdfs:comment "Total amount billed to the client for the work operation, calculated from quantity, time, rate, and water charge"@en, "Общая сумма, выставленная клиенту за выполненную работу, рассчитана исходя из количества, времени, тарифа и платы за воду"@ru .

eco:employeeTake a rdf:Property ;
    rdfs:domain eco:WorkTransaction ;
    rdfs:range xsd:decimal ;
    rdfs:label "Employee take"@en, "Доля сотрудника"@ru ;
    rdfs:comment "Portion of the billed amount allocated to the employee as compensation or commission in the base currency"@en, "Часть выставленной к оплате суммы, выделенная сотруднику в качестве вознаграждения или комиссионных, в базовой валюте"@ru .

eco:employee a rdf:Property ;
    rdfs:domain eco:WorkLog ;
    rdfs:range xsd:string ;
    rdfs:label "Employee"@en, "Сотрудник"@ru ;
    rdfs:comment "Name or identifier of the employee who performed the work"@en, "Имя или идентификационный номер сотрудника, выполнившего работу"@ru .

eco:dates a rdf:Property ;
    rdfs:domain eco:WorkLog ;
    rdfs:range xsd:string ;
    rdfs:label "Dates"@en, "Даты"@ru ;
    rdfs:comment "The start and end dates of the reporting period for this work log"@en, "Дата начала и завершения отчетного периода для данного рабочего журнала"@ru .

eco:totalAmountBilled a rdf:Property ;
    rdfs:domain eco:WorkLog ;
    rdfs:range xsd:decimal ;
    rdfs:label "Total amount billed"@en, "Общая сумма к оплате"@ru ;
    rdfs:comment "The total amount billed to the client for all work performed"@en, "Общая сумма, выставленная клиенту за выполнение всех работ"@ru .

eco:totalEmployeeTake a rdf:Property ;
    rdfs:domain eco:WorkLog ;
    rdfs:range xsd:decimal ;
    rdfs:label "Total employee take"@en, "Общая доля сотрудника"@ru ;
    rdfs:comment "The total amount allocated to an employee as compensation or commission"@en, "Общая сумма, выделенная сотруднику в качестве вознаграждения или комиссионных"@ru .
