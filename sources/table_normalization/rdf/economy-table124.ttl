@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:RoofingProduct a rdfs:Class ;
    rdfs:label "Roofing product"@en, "Кровельные материалы"@ru ;
    rdfs:comment "Roofing building material products with price, unit of measurement, tax and total cost information"@en, "Товары кровельного строительного материала с информацией о цене, единице измерения, налоге и общей стоимости"@ru .

# ==================== Datatype Properties ====================

eco:category a rdf:Property ;
    rdfs:domain eco:RoofingProduct ;
    rdfs:range xsd:string ;
    rdfs:label "Category"@en, "Категория"@ru ;
    rdfs:comment "High-level product category for roofing materials"@en, "Категория товара верхнего уровня для кровельных материалов"@ru .

eco:item a rdf:Property ;
    rdfs:domain eco:RoofingProduct ;
    rdfs:range xsd:string ;
    rdfs:label "Item"@en, "Товар"@ru ;
    rdfs:comment "Specific product name or description"@en, "Конкретное название или описание товара"@ru .

eco:unit a rdf:Property ;
    rdfs:domain eco:RoofingProduct ;
    rdfs:range xsd:string ;
    rdfs:label "Unit"@en, "Единица измерения"@ru ;
    rdfs:comment "Unit of measurement for the product"@en, "Единица измерения для товара"@ru .

eco:unitCost a rdf:Property ;
    rdfs:domain eco:RoofingProduct ;
    rdfs:range xsd:decimal ;
    rdfs:label "Unit cost"@en, "Стоимость за единицу"@ru ;
    rdfs:comment "Base price per unit of the product in the base currency"@en, "Базовая цена за единицу товара в базовой валюте"@ru .

eco:tax a rdf:Property ;
    rdfs:domain eco:RoofingProduct ;
    rdfs:range xsd:decimal ;
    rdfs:label "Tax"@en, "Налог"@ru ;
    rdfs:comment "Tax amount calculated as 5%"@en, "Сумма налога рассчитывается как 5%"@ru .

eco:taxableAmount a rdf:Property ;
    rdfs:domain eco:RoofingProduct ;
    rdfs:range xsd:decimal ;
    rdfs:label "Taxable amount"@en, "Облагаемая налогом сумма"@ru ;
    rdfs:comment "Taxable amount per unit used"@en, "Налогооблагаемая сумма за единицу товара"@ru .
