@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:ProducerPriceIndex a rdfs:Class ;
    rdfs:label "Producer price index"@en, "Индекс цен производителей"@ru ;
    rdfs:comment "Annual percent changes in selected producer price indexes, 1974 through 2023"@en, "Годовые процентные изменения отдельных индексов цен производителей, с 1974 по 2023 год"@ru .

# ==================== Datatype Properties ====================

eco:item a rdf:Property ;
    rdfs:domain eco:ProducerPriceIndex ;
    rdfs:range xsd:string ;
    rdfs:label "Item"@en, "Позиция"@ru ;
    rdfs:comment "The name of the producer price index category or item"@en, "Название категории или позиции индекса цен производителей"@ru .

eco:parentItem a rdf:Property ;
    rdfs:domain eco:ProducerPriceIndex ;
    rdfs:range xsd:string ;
    rdfs:label "Parent item"@en, "Родительская позиция"@ru ;
    rdfs:comment "The name of a more general (parent) category or item of the producer price index"@en, "Название более общей (родительской) категории или позиции индекса цен производителей"@ru .

eco:year a rdf:Property ;
    rdfs:domain eco:ProducerPriceIndex ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "Calendar year for which the percent change is measured"@en, "Календарный год, за который измеряется процентное изменение"@ru .

eco:percentChange a rdf:Property ;
    rdfs:domain eco:ProducerPriceIndex ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percent change"@en, "Процентное изменение"@ru ;
    rdfs:comment "Annual percent change value for the producer price index item"@en, "Значение годового процентного изменения для позиции индекса цен производителей"@ru .
