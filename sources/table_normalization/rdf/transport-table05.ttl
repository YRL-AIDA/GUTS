@prefix ts: <http://example.org/transport#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

ts:AccessibilityServiceStatistics a rdfs:Class ;
    rdfs:label "Accessibility service statistics"@en , "Статистика доступности услуг"@ru ;
    rdfs:comment "At risk users with reasonable access to key services by mode of travel, rural and urban areas, England, 2007 to 2013"@en , "Статистика пользователей, находящиеся в группе риска, но имеющие разумный доступ к основным услугам в зависимости от вида транспорта, а также типа жительства (сельские и городские районы) в Англии на 2007–2013 гг."@ru .

# ==================== Datatype Properties ====================

ts:year a rdf:Property ;
    rdfs:domain ts:AccessibilityServiceStatistics ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en , "Год"@ru ;
    rdfs:comment "The calendar year for which the accessibility data is reported"@en , "Календарный год, за который сообщаются данные о доступности"@ru .

ts:mode a rdf:Property ;
    rdfs:domain ts:AccessibilityServiceStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Travel mode"@en , "Вид транспорта"@ru ;
    rdfs:comment "The mode of travel used to assess accessibility"@en , "Вид транспорта, используемый для оценки доступности"@ru .

ts:keyService a rdf:Property ;
    rdfs:domain ts:AccessibilityServiceStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Key service"@en , "Ключевая услуга"@ru ;
    rdfs:comment "The key service being assessed"@en , "Ключевая услуга, доступность которой оценивается"@ru .

ts:urban a rdf:Property ;
    rdfs:domain ts:AccessibilityServiceStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Urban users"@en , "Городские пользователи"@ru ;
    rdfs:comment "Urban users served by the relevant service"@en , "Городские пользователи, обслуживаемые соответствующей службой"@ru .

ts:rural a rdf:Property ;
    rdfs:domain ts:AccessibilityServiceStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Rural users"@en , "Сельские пользователи"@ru ;
    rdfs:comment "Rural users served by the relevant service"@en , "Сельские пользователи, обслуживаемые соответствующей службой"@ru .

ts:urbanPercentage a rdf:Property ;
    rdfs:domain ts:AccessibilityServiceStatistics ;
    rdfs:range xsd:decimal ;
    rdfs:label "Urban user percentage"@en , "Процент городских пользователей"@ru ;
    rdfs:comment "Percentage of urban users with reasonable access"@en , "Процент городских пользователей с разумным доступом"@ru .

ts:ruralPercentage a rdf:Property ;
    rdfs:domain ts:AccessibilityServiceStatistics ;
    rdfs:range xsd:decimal ;
    rdfs:label "Rural user percentage"@en , "Процент сельских пользователей"@ru ;
    rdfs:comment "Percentage of rural users with reasonable access"@en , "Процент сельских пользователей с разумным доступом"@ru .
