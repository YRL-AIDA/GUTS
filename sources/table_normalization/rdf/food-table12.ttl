@prefix fd: <http://example.org/food#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

fd:FoodExpenditureSeries a rdfs:Class ;
    rdfs:label "Food expenditure series"@en, "Серия данных о расходах на продукты питания"@ru ;
    rdfs:comment "Food expenditure series for a specific year, food category, price type, and purchaser type in the United States"@en, "Данные о расходах на продукты питания для конкретного года, места потребления, типа цен и типа покупателя в США"@ru .

# ==================== Datatype Properties ====================

fd:year a rdf:Property ;
    rdfs:domain fd:FoodExpenditureSeries ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "Calendar year of observation"@en, "Календарный год наблюдения"@ru .

fd:purchaserCategory a rdf:Property ;
    rdfs:domain fd:FoodExpenditureSeries ;
    rdfs:range xsd:string ;
    rdfs:label "Purchaser category"@en, "Категория покупателя"@ru ;
    rdfs:comment "Name of the category of food buyers"@en, "Название категории покупателей продуктов питания"@ru .

fd:foodCategory a rdf:Property ;
    rdfs:domain fd:FoodExpenditureSeries ;
    rdfs:range xsd:string ;
    rdfs:label "Food category"@en, "Категория питания"@ru ;
    rdfs:comment "The category of food: FAH (Food at Home) or FAFH (Food Away from Home)"@en, "Категория питания: FAH (продукты для дома) или FAFH (питание вне дома)"@ru .

fd:priceType a rdf:Property ;
    rdfs:domain fd:FoodExpenditureSeries ;
    rdfs:range xsd:string ;
    rdfs:label "Price type"@en, "Тип цены"@ru ;
    rdfs:comment "The type of price adjustment"@en, "Тип корректировки цены"@ru .

fd:expenditureCost a rdf:Property ;
    rdfs:domain fd:FoodExpenditureSeries ;
    rdfs:range xsd:decimal ;
    rdfs:label "Expenditure cost"@en, "Стоимость расходов"@ru ;
    rdfs:comment "The numeric value of food expenditure in U.S. dollars for the given year"@en, "Числовое значение расходов на продукты питания в долларах США для данного года"@ru .
