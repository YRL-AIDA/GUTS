@prefix emp: <http://example.org/employment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

emp:EmploymentStatistics a rdfs:Class ;
    rdfs:label "Employment statistics"@en, "Статистика занятости"@ru ;
    rdfs:comment "Employment statistics for the civilian non-institutional population of the United States, disaggregated by gender and category"@en, "Статистические данные занятости гражданского неинституционального населения США с детализацией по полу и категориям"@ru .

# ==================== Datatype Properties ====================

emp:year a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "The calendar year for which the statistic is reported"@en, "Календарный год, за который приводятся статистические данные"@ru .

emp:gender a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Gender"@en, "Пол"@ru ;
    rdfs:comment "The gender of the population group"@en, "Пол группы населения"@ru .

emp:civilianNoninstitutionalPopulation a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Civilian noninstitutional population"@en, "Гражданское неинституциональное население"@ru ;
    rdfs:comment "The size of the civilian noninstitutional population in thousands of persons"@en, "Численность гражданского неинституционального населения в тысячах человек"@ru .

emp:totalCivilianLaborForce a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Total civilian labor force"@en, "Общая численность гражданской рабочей силы"@ru ;
    rdfs:comment "The total number of persons in the civilian labor force (in thousands)"@en, "Общее число лиц, входящих в состав гражданской рабочей силы (в тысячах)"@ru .

emp:civilianLaborForcePercent a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percent of civilian labor force"@en, "Процент гражданской рабочей силы"@ru ;
    rdfs:comment "The percentage of the civilian noninstitutional population that is in the labor force"@en, "Процент гражданского неинституционального населения, входящего в состав рабочей силы"@ru .

emp:totalEmployed a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Total employed"@en, "Общая численность занятых"@ru ;
    rdfs:comment "The total number of employed persons (in thousands)"@en, "Общее число занятых (в тысячах)"@ru .

emp:percentEmployed a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percent of employed"@en, "Процент занятых"@ru ;
    rdfs:comment "The percentage of the civilian noninstitutional population that is employed"@en, "Процент занятого гражданского населения, не находящегося в учреждениях закрытого типа"@ru .

emp:agriculture a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Employed in agriculture"@en, "Занятых в сельском хозяйстве"@ru ;
    rdfs:comment "The total number of people employed in agriculture"@en, "Общее количество занятых в сельском хозяйстве"@ru .

emp:nonagriculturalIndustries a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Employed in non-agricultural industries"@en, "Занятых в несельскохозяйственных отраслях"@ru ;
    rdfs:comment "The total number of people employed in non-agricultural sectors"@en, "Общее количество занятых в несельскохозяйственных отраслях"@ru .

emp:unemployedNumber a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Number of unemployed"@en, "Число безработных"@ru ;
    rdfs:comment "The number of unemployed persons (in thousands)"@en, "Число безработных (в тысячах)"@ru .

emp:unemployedPercent a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percent of unemployed"@en, "Процент безработных"@ru ;
    rdfs:comment "The percentage of the civilian labor force that is unemployed"@en, "Процент безработных среди гражданского населения"@ru .

emp:notInLaborForce a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Not in labor force"@en, "Не входит в состав рабочей силы"@ru ;
    rdfs:comment "The number of persons not in the labor force (in thousands)"@en, "Число лиц, не входящих в состав рабочей силы (в тысячах)"@ru .
