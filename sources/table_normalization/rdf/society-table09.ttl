@prefix soc: <http://example.org/society#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

soc:SupplementationObservation a rdfs:Class ;
    rdfs:label "Supplementation observation"@en , "Наблюдение за выплатой дополнительного пособия"@ru ;
    rdfs:comment "Observation of recipient count and average monthly payment for supplementation recipients in the United States by region and state"@en , "Наблюдение о количестве и среднем ежемесячном платеже получателей дополнительного пособия в США по регионам и штатам"@ru .

soc:ObservationAggregation a rdfs:Class ;
    rdfs:label "Observation aggregation"@en , "Агрегирование наблюдений"@ru ;
    rdfs:comment "Observation aggregation for supplementation"@en , "Агрегирование наблюдений за выплатой дополнительного пособия"@ru .

# ==================== Datatype Properties ====================

soc:region a rdf:Property ;
    rdfs:domain soc:SupplementationObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Region"@en , "Регион"@ru ;
    rdfs:comment "Region of the United States in which observation was conducted"@en , "Регион США в котором проводилось наблюдение"@ru .

soc:area a rdf:Property ;
    rdfs:domain soc:SupplementationObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Area"@en , "Область"@ru ;
    rdfs:comment "The state or area of the United States in which the observation was conducted"@en , "Штат или область США в которой проводилось наблюдение"@ru .

soc:number a rdf:Property ;
    rdfs:domain soc:SupplementationObservation ;
    rdfs:range xsd:integer ;
    rdfs:label "Number of recipients"@en , "Количество получателей"@ru ;
    rdfs:comment "Number of supplementation recipients in absolute figures"@en , "Количество получателей дополнительного пособия в абсолютных числах"@ru .

soc:averageMonthlyPayment a rdf:Property ;
    rdfs:domain soc:SupplementationObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Average monthly payment"@en , "Средний ежемесячный платеж"@ru ;
    rdfs:comment "Average monthly payment of supplementation recipient in US dollars"@en , "Средний ежемесячный платёж получателя дополнительного пособия в долларах США"@ru .

soc:number a rdf:Property ;
    rdfs:domain soc:ObservationAggregation ;
    rdfs:range xsd:integer ;
    rdfs:label "Total number of recipients"@en , "Общеее количество получателей"@ru ;
    rdfs:comment "Total number of supplementation recipients across all regions of the United States"@en , "Общее количество получателей дополнительного пособия по всем регионам США"@ru .

soc:averageMonthlyPayment a rdf:Property ;
    rdfs:domain soc:ObservationAggregation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Average monthly payment"@en , "Средний ежемесячный платеж"@ru ;
    rdfs:comment "Average monthly payment of supplementation recipient in US dollars across all regions of the United States"@en , "Средний ежемесячный платёж получателя дополнительного пособия в долларах США по всем регионам США"@ru .
