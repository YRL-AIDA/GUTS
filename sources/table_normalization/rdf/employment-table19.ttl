@prefix emp: <http://example.org/employment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

emp:EmploymentStatistics a rdfs:Class ;
    rdfs:label "Employment statistics"@en, "Статистика занятости"@ru ;
    rdfs:comment "U.S. civilian employment statistics by industry, and demographic group"@en, "Статистические данные занятости гражданского населения США с детализацией по отраслям и демографической группе"@ru .

# ==================== Datatype Properties ====================

emp:year a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "The calendar year for which the statistic is reported"@en, "Календарный год, за который приводятся статистические данные"@ru .

emp:industry a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Industry"@en, "Отрасль"@ru ;
    rdfs:comment "Industry name"@en, "Название отрасли"@ru .

emp:demographicGroup a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Demographic group"@en, "Демографическая группа"@ru ;
    rdfs:comment "The demographic group covered by the statistic"@en, "Демографическая группа, охватываемая данным статистическим показателем"@ru .

emp:totalEmployed a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Total employed"@en, "Общая численность занятых"@ru ;
    rdfs:comment "Total number of employed persons in thousands for the given industry"@en, "Общее количество занятых лиц в тысячах для указанной отрасли"@ru .

emp:percentEmployed a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percent of total employed"@en, "Процент от общего числа занятых"@ru ;
    rdfs:comment "The percentage share of the demographic group within the total employed for the specified industry"@en, "Процентная доля демографической группы от общего числа занятых в указанной отрасли"@ru .
