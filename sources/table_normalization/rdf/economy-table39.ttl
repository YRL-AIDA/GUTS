@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:CommissionSummary a rdfs:Class ;
    rdfs:label "Commission summary"@en, "Сводка комиссий"@ru ;
    rdfs:comment "Annual summary of commissions on clients' insurance policies"@en, "Годовая сводка комиссий по страховым полисам клиентов"@ru .

# ==================== Datatype Properties ====================

eco:client a rdf:Property ;
    rdfs:domain eco:CommissionSummary ;
    rdfs:range xsd:string ;
    rdfs:label "Client"@en, "Клиент"@ru ;
    rdfs:comment "The name or identifier of the client who holds the insurance policy"@en, "Имя или идентификатор клиента, являющегося владельцем страхового полиса"@ru .

eco:policy a rdf:Property ;
    rdfs:domain eco:CommissionSummary ;
    rdfs:range xsd:string ;
    rdfs:label "Policy"@en, "Полис"@ru ;
    rdfs:comment "The unique policy identifier or number assigned to the insurance contract"@en, "Уникальный идентификатор или номер полиса, присвоенный страховому договору"@ru .

eco:year a rdf:Property ;
    rdfs:domain eco:CommissionSummary ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "The calendar year for which the commission amount is recorded"@en, "Календарный год, за который зафиксирована сумма комиссии"@ru .

eco:commission a rdf:Property ;
    rdfs:domain eco:CommissionSummary ;
    rdfs:range xsd:decimal ;
    rdfs:label "Commission"@en, "Комиссия"@ru ;
    rdfs:comment "The commission amount in US dollars for the given policy and year"@en, "Размер комиссионных в долларах США за данный полис и год"@ru .
