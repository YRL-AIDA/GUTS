@prefix emp: <http://example.org/employment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

emp:EmploymentStatistics a rdfs:Class ;
    rdfs:label "Employment statistics"@en, "Статистика занятости"@ru ;
    rdfs:comment "Annual statistics on the number of people employed in non-agricultural sectors for a specific demographic group"@en, "Ежегодные статистические данные численности занятых в неаграрных отраслях для конкретной демографической группы"@ru .

# ==================== Datatype Properties ====================

emp:year a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "The calendar year for which the statistic is reported"@en, "Календарный год, за который приводятся статистические данные"@ru .

emp:demographicGroup a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Demographic group"@en, "Демографическая группа"@ru ;
    rdfs:comment "The demographic group covered by the statistic"@en, "Демографическая группа, охватываемая данным статистическим показателем"@ru .

emp:sex a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Sex"@en, "Пол"@ru ;
    rdfs:comment "Sex category"@en, "Категория пола"@ru .

emp:ageGroup a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Age group"@en, "Возрастная группа"@ru ;
    rdfs:comment "Age group category"@en, "Категория возрастной группы"@ru .

emp:industry a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Industry"@en, "Отрасль"@ru ;
    rdfs:comment "Name of non-agricultural industry category"@en, "Название категории неаграрной отрасли"@ru .

emp:totalEmployed a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Total employed"@en, "Общая численность занятых"@ru ;
    rdfs:comment "Total number of employed persons in thousands for the specified demographic and age group, gender and industry"@en, "Общее количество занятых лиц в тысячах для указанной демографической и возрастной группе, полу и отрасли"@ru .
