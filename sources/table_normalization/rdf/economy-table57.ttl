@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:MonthlyExpenseReport a rdfs:Class ;
    rdfs:label "Monthly expense report"@en, "Ежемесячный отчет о расходах"@ru ;
    rdfs:comment "A monthly report containing the monetary amount of expenses for a specific cost item in a specific reporting month"@en, "Ежемесячный отчет, содержащий денежную сумму расхода для конкретной статьи затрат в конкретном отчетном месяце"@ru .

# ==================== Datatype Properties ====================

eco:month a rdf:Property ;
    rdfs:domain eco:MonthlyExpenseReport ;
    rdfs:range xsd:string ;
    rdfs:label "Month"@en, "Месяц"@ru ;
    rdfs:comment "Timestamp of the reporting period"@en, "Временная метка отчетного периода"@ru .

eco:consumption a rdf:Property ;
    rdfs:domain eco:MonthlyExpenseReport ;
    rdfs:range xsd:string ;
    rdfs:label "Consumption"@en, "Расходы"@ru ;
    rdfs:comment "The expense category or description identifying the type of operational cost"@en, "Категория или описание расходов, определяющее тип операционных затрат"@ru .

eco:amount a rdf:Property ;
    rdfs:domain eco:MonthlyExpenseReport ;
    rdfs:range xsd:decimal ;
    rdfs:label "Amount"@en, "Сумма"@ru ;
    rdfs:comment "The monetary value of the expense for the given category in the given month"@en, "Денежная стоимость расходов по данной категории за данный месяц"@ru .
