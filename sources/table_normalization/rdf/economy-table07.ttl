@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:IndividualInsolvencyObservation a rdfs:Class ;
    rdfs:label "Individual insolvency observation"@en, "Наблюдение за индивидуальной неплатежеспособностью"@ru ;
    rdfs:comment "The observation of individual insolvency rolling 12-month rate per 10,000 adults in England and Wales, not seasonally adjusted, 1 January 2012 to 30 June 2022"@en, "Наблюдение за показателем индивидуальной неплатежеспособности за 12 месяцев на 10 000 взрослых в Англии и Уэльсе без учета сезонных колебаний, с 1 января 2012 г. по 30 июня 2022 г."@ru .

# ==================== Datatype Properties ====================

eco:year a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "Calendar year of observation"@en, "Календарный год наблюдения"@ru .

eco:quarter a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Quarter"@en, "Квартал"@ru ;
    rdfs:comment "The time period: Q1, Q2, Q3, Q4 for quarterly data"@en, "Временной период: Q1, Q2, Q3, Q4 для квартальных данных"@ru .

eco:insolvencyType a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Insolvency type"@en, "Тип несостоятельности"@ru ;
    rdfs:comment "The type of insolvency procedure"@en, "Тип процедуры несостоятельности"@ru .

eco:insolvencyRate a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Rate of insolvency"@en, "Уровень неплатежеспособности"@ru ;
    rdfs:comment "The rolling 12-month insolvency rate per 10,000 adults for the given year, quarter, and insolvency type"@en, "Скользящий 12-месячный показатель неплатежеспособности на 10 000 взрослых для данного года, квартала и типа несостоятельности"@ru .

eco:rateChange a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Rate change"@en, "Изменение показателя"@ru ;
    rdfs:comment "Change in rate per 10,000 adults, latest quarter compared with the previous one"@en, "Изменение показателя на 10 000 взрослых за последний квартал по сравнению с предыдущим"@ru .

eco:dataStatus a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Data status"@en, "Статус данных"@ru ;
    rdfs:comment "The quality flag of the data (revised, provisional, or empty)"@en, "Флаг качества данных (пересмотренные, предварительные или пустое значение)"@ru .
