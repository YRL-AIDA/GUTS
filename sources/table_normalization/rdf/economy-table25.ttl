@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:NationalIncome a rdfs:Class ;
    rdfs:label "Annual national disposable income"@en, "Национальный доход"@ru ;
    rdfs:comment "Annual national disposable income, US $, volume, constant PPPs"@en, "Годовой национальный располагаемый доход, доллары США, объем, постоянный ППС"@ru .

# ==================== Datatype Properties ====================

eco:timePeriod a rdf:Property ;
    rdfs:domain eco:NationalIncome ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "Calendar year of observation"@en, "Календарный год наблюдения"@ru .

eco:referenceArea a rdf:Property ;
    rdfs:domain eco:NationalIncome ;
    rdfs:range xsd:string ;
    rdfs:label "Country"@en, "Страна"@ru ;
    rdfs:comment "Country name"@en, "Наименование страны"@ru .

eco:combinedMeasureUnit a rdf:Property ;
    rdfs:domain eco:NationalIncome ;
    rdfs:range xsd:string ;
    rdfs:label "Combined unit of measure"@en, "Комбинированная единица измерения"@ru ;
    rdfs:comment "The unit of measurement for the income value, including currency, PPP adjustment, volume indexing, and scale"@en, "Единица измерения значения дохода, включающая валюту, корректировку по ППС, индексирование объема и масштаб"@ru .

eco:incomeValue a rdf:Property ;
    rdfs:domain eco:NationalIncome ;
    rdfs:range xsd:decimal ;
    rdfs:label "Income value"@en, "Значение дохода"@ru ;
    rdfs:comment "The numerical value of the disposable income in the specified unit of measure"@en, "Числовое значение располагаемого дохода в указанной единице измерения"@ru .
