@prefix env: <http://example.org/environment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

env:AgriculturalHorticulturalSurvey a rdfs:Class ;
    rdfs:label "Agricultural and horticultural survey"@en, "Исследование сельского хозяйства и садоводства"@ru ;
    rdfs:comment "Annual statistics of the number of livestock and poultry of a given category in a given region or county in England"@en, "Ежегодные статистические данные наблюдения за количеством скота и птицы определенной категории определенного региона или графства в Англии"@ru .

# ==================== Datatype Properties ====================

env:region a rdf:Property ;
    rdfs:domain env:AgriculturalHorticulturalSurvey ;
    rdfs:range xsd:string ;
    rdfs:label "Region"@en, "Регион"@ru ;
    rdfs:comment "The geographical region or county in England"@en, "Географический регион или графство в Англии"@ru .

env:livestockCategory a rdf:Property ;
    rdfs:domain env:AgriculturalHorticulturalSurvey ;
    rdfs:range xsd:string ;
    rdfs:label "Livestock category"@en, "Категория скота"@ru ;
    rdfs:comment "The main category of livestock being measured"@en, "Основная категория скота, подвергающихся измерениям"@ru .

env:livestockName a rdf:Property ;
    rdfs:domain env:AgriculturalHorticulturalSurvey ;
    rdfs:range xsd:string ;
    rdfs:label "Livestock name"@en, "Название скота"@ru ;
    rdfs:comment "The specific name of livestock"@en, "Конкретное название скота"@ru .

env:year a rdf:Property ;
    rdfs:domain env:AgriculturalHorticulturalSurvey ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "Year of statistical observation"@en, "Год статистического наблюдения"@ru .

env:livestockNumber a rdf:Property ;
    rdfs:domain env:AgriculturalHorticulturalSurvey ;
    rdfs:range xsd:integer ;
    rdfs:label "Number of livestock"@en, "Количество скота"@ru ;
    rdfs:comment "The numerical value representing the number of livestock"@en, "Числовое значение, представляющее количество скота"@ru .

env:percentageChange a rdf:Property ;
    rdfs:domain env:AgriculturalHorticulturalSurvey ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percentage change"@en, "Процентное изменение"@ru ;
    rdfs:comment "Percentage change in livestock numbers over the previous year"@en, "Процентное изменение количество скота за предыдущий год"@ru .
