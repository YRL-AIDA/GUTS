@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:FFELProgramLoansLocation a rdfs:Class ;
    rdfs:label "FFEL program loans location"@en, "Местонахождение займов по программе FFEL"@ru ;
    rdfs:comment "Data on outstanding balances and recipient count for Federal Family Education Loan (FFEL) program loans held by a specific entity during a fiscal quarter"@en, "Данные о непогашенных остатках и количестве получателей по займам программы федеральных семейных образовательных займов (FFEL), удерживаемым конкретным субъектом в течение финансового квартала"@ru .

# ==================== Datatype Properties ====================

eco:year a rdf:Property ;
    rdfs:domain eco:FFELProgramLoansLocation ;
    rdfs:range xsd:gYear ;
    rdfs:label "year"@en, "Год"@ru ;
    rdfs:comment "Federal fiscal year for the reporting period"@en, "Федеральный финансовый год отчетного периода"@ru .

eco:quarter a rdf:Property ;
    rdfs:domain eco:FFELProgramLoansLocation ;
    rdfs:range xsd:string ;
    rdfs:label "Quarter"@en, "Квартал"@ru ;
    rdfs:comment "Quarter within the fiscal year (1–4) for the reporting period"@en, "Квартал в рамках финансового года (1–4) для отчетного периода"@ru .

eco:loanHolderType a rdf:Property ;
    rdfs:domain eco:FFELProgramLoansLocation ;
    rdfs:range xsd:string ;
    rdfs:label "Loan holder type"@en, "Тип держателя займа"@ru ;
    rdfs:comment "The entity type holding the FFEL loans"@en, "Тип субъекта, удерживающего займы FFEL"@ru .

eco:dollarsOutstanding a rdf:Property ;
    rdfs:domain eco:FFELProgramLoansLocation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Dollars outstanding"@en, "Сумма непогашенных платежей"@ru ;
    rdfs:comment "The total outstanding principal and interest balance in billions of US dollars"@en, "Общий непогашенный остаток основной суммы и процентов в миллиардах долларов США"@ru .

eco:recipients a rdf:Property ;
    rdfs:domain eco:FFELProgramLoansLocation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Recipients"@en, "Получатели"@ru ;
    rdfs:comment "The number of loan recipients in millions of individuals"@en, "Количество получателей займов в миллионах человек"@ru .
