@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:IndividualInsolvencyObservation a rdfs:Class ;
    rdfs:label "Individual insolvency observation"@en, "Наблюдение за индивидуальной неплатежеспособностью"@ru ;
    rdfs:comment "The observation of individual insolvencies in England and Wales, not seasonally adjusted, 1 January 2012 to 30 June 2022"@en, "Наблюдение за количеством случаев несостоятельности отдельных лиц в Англии и Уэльсе без учета сезонных колебаний, с 1 января 2012 г. по 30 июня 2022 г."@ru .

# ==================== Datatype Properties ====================

eco:year a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "Calendar year of observation"@en, "Календарный год наблюдения"@ru .

eco:quarter a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Quarter"@en, "Квартал"@ru ;
    rdfs:comment "The time period: Q1, Q2, Q3, Q4 for quarterly data"@en, "Временной период: Q1, Q2, Q3, Q4 для квартальных данных"@ru .

eco:insolvencyType a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Insolvency type"@en, "Тип несостоятельности"@ru ;
    rdfs:comment "The type of insolvency procedure"@en, "Тип процедуры несостоятельности"@ru .

eco:insolvencyNumber a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:integer ;
    rdfs:label "Number of insolvencies"@en, "Количество банкротств"@ru ;
    rdfs:comment "The number of individual insolvencies for a given time period"@en, "Количество случаев индивидуальной неплатежеспособности за определенный период времени"@ru .

eco:percentageChange a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:integer ;
    rdfs:label "Percentage change"@en, "Процентное изменение"@ru ;
    rdfs:comment "Percentage change for the latest quarter compared to the previous one"@en, "Процентное изменение за последний квартал по сравнению с предыдущим"@ru .

eco:dataStatus a rdf:Property ;
    rdfs:domain eco:IndividualInsolvencyObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Data status"@en, "Статус данных"@ru ;
    rdfs:comment "The quality flag of the data (revised, provisional, or empty)"@en, "Флаг качества данных (пересмотренные, предварительные или пустое значение)"@ru .
