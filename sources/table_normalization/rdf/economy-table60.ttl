@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:WorkTicket a rdfs:Class ;
    rdfs:label "Work ticket"@en, "Рабочая смена"@ru ;
    rdfs:comment "Information on the work shift or service provided, including data on equipment, client, and financial indicators"@en, "Информация по рабочей смене или оказанной услуге, включающая данные об оборудовании, клиенте и финансовых показателях"@ru .

eco:EmployeePaymentSummary a rdfs:Class ;
    rdfs:label "Employee payment summary"@en, "Сводка по выплатам сотрудника"@ru ;
    rdfs:comment "Summary information on all employee payments for a specific time period"@en, "Сводная информация по всем выплатам сотрудника за определенный временной период"@ru .

# ==================== Datatype Properties ====================

eco:employee a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:string ;
    rdfs:label "Employee"@en, "Сотрудник"@ru ;
    rdfs:comment "Name or identifier of the employee who performed the work"@en, "Имя или идентификатор сотрудника, выполнившего работу"@ru .

eco:date a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:date ;
    rdfs:label "Date"@en, "Дата"@ru ;
    rdfs:comment "Calendar date when the work was performed"@en, "Календарная дата выполнения работы"@ru .

eco:ticketNumber a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:integer ;
    rdfs:label "Ticket number"@en, "Номер смены"@ru ;
    rdfs:comment "Unique identifier of the work ticket as assigned in the logging system"@en, "Уникальный идентификатор рабочей смены (наряда), присвоенный в системе учета"@ru .

eco:truckNumber a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:string ;
    rdfs:label "Truck number"@en, "Номер грузовика"@ru ;
    rdfs:comment "Identifier of the truck used for the work entry"@en, "Идентификатор грузовика, использованного для выполнения работы"@ru .

eco:trailerNumber a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:string ;
    rdfs:label "Trailer number"@en, "Номер прицепа"@ru ;
    rdfs:comment "Identifier of the trailer used for the work entry"@en, "Идентификатор прицепа, использованного для выполнения работы"@ru .

eco:company a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:string ;
    rdfs:label "Company"@en, "Компания"@ru ;
    rdfs:comment "Name of the client company for which the work was performed"@en, "Название компании-заказчика, для которой выполнялась работа"@ru .

eco:product a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:string ;
    rdfs:label "Product"@en, "Продукт"@ru ;
    rdfs:comment "Type of service or product delivered"@en, "Тип оказанной услуги или продукта"@ru .

eco:quantity a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:integer ;
    rdfs:label "Quantity in bbls"@en, "Количество в баррелях"@ru ;
    rdfs:comment "Volume of product handled, measured in barrels (bbls)"@en, "Объем обработанного продукта, измеренный в баррелях"@ru .

eco:time a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:decimal ;
    rdfs:label "Time"@en, "Время"@ru ;
    rdfs:comment "Duration of work performed, measured in hours"@en, "Продолжительность выполненной работы, измеренная в часах"@ru .

eco:rateValue a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:decimal ;
    rdfs:label "Rate value"@en, "Значение ставки"@ru ;
    rdfs:comment "Numeric value of the billing rate in US dollars"@en, "Числовое значение тарифной ставки в долларах США"@ru .

eco:waterCharge a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:decimal ;
    rdfs:label "Water charge"@en, "Палата за воду"@ru ;
    rdfs:comment "Additional charge for water usage"@en, "Дополнительная плата за использование воды"@ru .

eco:amountBilled a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:decimal ;
    rdfs:label "Amount billed"@en, "Сумма к оплате"@ru ;
    rdfs:comment "Total amount invoiced to the client for this work"@en, "Общая сумма, выставленная клиенту за данную работу"@ru .

eco:employeeTake a rdf:Property ;
    rdfs:domain eco:WorkTicket ;
    rdfs:range xsd:decimal ;
    rdfs:label "Employee take"@en, "Доля сотрудника"@ru ;
    rdfs:comment "Portion of the billed amount allocated to the employee as compensation"@en, "Часть выставленной суммы, выделяемая сотруднику в качестве вознаграждения"@ru .

eco:employee a rdf:Property ;
    rdfs:domain eco:EmployeePaymentSummary ;
    rdfs:range xsd:string ;
    rdfs:label "Employee"@en, "Сотрудник"@ru ;
    rdfs:comment "Employee name or identifier"@en, "Имя или идентификатор сотрудника"@ru .

eco:dates a rdf:Property ;
    rdfs:domain eco:EmployeePaymentSummary ;
    rdfs:range xsd:string ;
    rdfs:label "Dates"@en, "Даты"@ru ;
    rdfs:comment "Date range"@en, "Диапазон дат"@ru .

eco:totalAmountBilled a rdf:Property ;
    rdfs:domain eco:EmployeePaymentSummary ;
    rdfs:range xsd:decimal ;
    rdfs:label "Total amount billed"@en, "Общая сумма к оплате"@ru ;
    rdfs:comment "Total amount to be paid for all work"@en, "Общая сумма к оплате за всю работу"@ru .

eco:totalEmployeeTake a rdf:Property ;
    rdfs:domain eco:EmployeePaymentSummary ;
    rdfs:range xsd:decimal ;
    rdfs:label "Total employee take"@en, "Все доли сотрудника"@ru ;
    rdfs:comment "All amounts issued and allocated to the employee as remuneration"@en, "Все выставленные суммы, выделяемые сотруднику в качестве вознаграждения"@ru .
