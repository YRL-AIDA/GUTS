@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:MacroeconomicIndicatorObservation a rdfs:Class ;
    rdfs:label "Macroeconomic indicator observation"@en, "Наблюдение за макроэкономическими показателями"@ru ;
    rdfs:comment "Macroeconomic observation data for specific countries"@en, "Данные наблюдений за макроэкономическими показателями для определенных стран"@ru .

# ==================== Datatype Properties ====================

eco:year a rdf:Property ;
    rdfs:domain eco:MacroeconomicIndicatorObservation ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "Calendar year of observation"@en, "Календарный год наблюдения"@ru .

eco:country a rdf:Property ;
    rdfs:domain eco:MacroeconomicIndicatorObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Country"@en, "Страна"@ru ;
    rdfs:comment "Country name"@en, "Наименование страны"@ru .

eco:inflation a rdf:Property ;
    rdfs:domain eco:MacroeconomicIndicatorObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Inflation"@en, "Инфляция"@ru ;
    rdfs:comment "Percentage change in GDP deflator each year"@en, "Процентное изменение дефлятора ВВП за каждый год"@ru .

eco:realWage a rdf:Property ;
    rdfs:domain eco:MacroeconomicIndicatorObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Real wage"@en, "Реальная заработная плата"@ru ;
    rdfs:comment "Percentage change in real wages per year"@en, "Процентное изменение реальной заработной платы в год"@ru .
