@prefix emp: <http://example.org/employment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

emp:EmploymentStatistics a rdfs:Class ;
    rdfs:label "Employment statistics"@en, "Статистика занятости"@ru ;
    rdfs:comment "Employment statistics for the civilian non-institutional population of the United States in 25 years and over by educational attainment, sex, race, and Hispanic or Latino ethnicity"@en, "Ежегодные статистические данные занятости гражданского неинституционального населения США в возрасте 25 лет и старше зависимости от уровня образования, пола, расы и принадлежности к латиноамериканской или испанской этнической группе"@ru .

# ==================== Datatype Properties ====================

emp:year a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "The calendar year for which the statistic is reported"@en, "Календарный год, за который приводятся статистические данные"@ru .

emp:sex a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Sex"@en, "Пол"@ru ;
    rdfs:comment "Sex category"@en, "Категория пола"@ru .

emp:race a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Race"@en, "Раса"@ru ;
    rdfs:comment "Race category"@en, "Категория расы"@ru .

emp:ethnicity a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Ethnicity"@en, "Этническая принадлежность"@ru ;
    rdfs:comment "Ethnicity category"@en, "Категория этнической принадлежности"@ru .

emp:educationLevel a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Education level"@en, "Уровень образования"@ru ;
    rdfs:comment "The educational attainment level"@en, "Уровень образования"@ru .

emp:civilianNoninstitutionalPopulation a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Civilian noninstitutional population"@en, "Гражданское неинституциональное население"@ru ;
    rdfs:comment "The size of the civilian noninstitutional population in thousands of persons"@en, "Численность гражданского неинституционального населения в тысячах человек"@ru .

emp:civilianLaborForce a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Civilian labor force"@en, "Численность гражданской рабочей силы"@ru ;
    rdfs:comment "The total number of persons in the civilian labor force (in thousands)"@en, "Общее число лиц, входящих в состав гражданской рабочей силы (в тысячах)"@ru .

emp:participationRate a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:decimal ;
    rdfs:label "Participation rate"@en, "Уровень участия"@ru ;
    rdfs:comment "Labor force participation rate of the civilian non-institutional population"@en, "Уровень участия гражданского неинституционального населения, входящего в состав рабочей силы"@ru .

emp:employed a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Employed"@en, "Численность занятых"@ru ;
    rdfs:comment "The total number of employed persons (in thousands)"@en, "Общее число занятых (в тысячах)"@ru .

emp:employmentPopulationRatio a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:decimal ;
    rdfs:label "Employment-population ratio"@en, "Соотношение занятости к численности населения"@ru ;
    rdfs:comment "Percentage of employed civilian population to the population"@en, "Процент занятого гражданского населения к численности населения"@ru .

emp:unemployed a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Unemployed"@en, "Число безработных"@ru ;
    rdfs:comment "The number of unemployed persons (in thousands)"@en, "Число безработных (в тысячах)"@ru .

emp:unemploymentRate a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:decimal ;
    rdfs:label "Unemployment rate"@en, "Уровень безработицы"@ru ;
    rdfs:comment "The percentage of the civilian labor force that is unemployed"@en, "Процент безработных среди гражданского населения"@ru .
