@prefix wf: <http://example.org/welfare#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

wf:EmploymentCostIndex a rdfs:Class ;
    rdfs:label "Employment cost index"@en , "Индекс стоимости рабочей силы"@ru ;
    rdfs:comment "Employment cost index for benefits, by occupational group, industry, and bargaining status"@en , "Индекс стоимости рабочей силы с учетом льгот, по профессиональным группам, отраслям и статусу участника коллективного договора"@ru .

wf:IndexAggregation a rdfs:Class ;
    rdfs:label "Index aggregation"@en , "Агрегация индексов"@ru ;
    rdfs:comment "Aggregation of employment cost indices by worker categories"@en , "Агрегация индексов стоимости рабочей силы по категориям работников"@ru .

# ==================== Datatype Properties ====================

wf:workerCategory a rdf:Property ;
    rdfs:domain wf:EmploymentCostIndex ;
    rdfs:range xsd:string ;
    rdfs:label "Worker category"@en , "Категория работников"@ru ;
    rdfs:comment "General category of workers"@en , "Общая категория работников"@ru .

wf:criteriaType a rdf:Property ;
    rdfs:domain wf:EmploymentCostIndex ;
    rdfs:range xsd:string ;
    rdfs:label "Criteria type"@en , "Тип критерия"@ru ;
    rdfs:comment "The type of criterion by which the employee index is assessed"@en , "Тип критерия по которому оценивается индекс работника"@ru .

wf:criteriaName a rdf:Property ;
    rdfs:domain wf:EmploymentCostIndex ;
    rdfs:range xsd:string ;
    rdfs:label "Criteria name"@en , "Название критерия"@ru ;
    rdfs:comment "The specific name of the criterion to which the employee belongs"@en , "Конкретное название критерия к которому относится работник"@ru .

wf:criteriaNote a rdf:Property ;
    rdfs:domain wf:EmploymentCostIndex ;
    rdfs:range xsd:string ;
    rdfs:label "Criteria note"@en , "Примечание к критерию"@ru ;
    rdfs:comment "A note to a specific criterion, disclosing its content"@en , "Примечание к конкретному критерию, раскрывающее его содержание"@ru .

wf:date a rdf:Property ;
    rdfs:domain wf:EmploymentCostIndex ;
    rdfs:range xsd:date ;
    rdfs:label "Date"@en , "Дата"@ru ;
    rdfs:comment "Time period for which the labor cost index was measured"@en , "Временной период за который проведено измерение индекса стоимости рабочей силы"@ru .

wf:index a rdf:Property ;
    rdfs:domain wf:EmploymentCostIndex ;
    rdfs:range xsd:decimal ;
    rdfs:label "Index"@en , "Индекс"@ru ;
    rdfs:comment "Employment cost index for benefits (Dec.2005=100)"@en , "Индекс стоимости рабочей силы с учетом льгот (декабрь 2005 г. = 100)"@ru .

wf:threeMonthPercentChange a rdf:Property ;
    rdfs:domain wf:EmploymentCostIndex ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percent changes for	3-months"@en , "Процентные изменения за 3 месяца"@ru ;
    rdfs:comment "Percent changes for 3-months ended to the measurement date"@en , "Процентные изменения за 3 месяца относительно даты измерения"@ru .

wf:twelveMonthPercentChange a rdf:Property ;
    rdfs:domain wf:EmploymentCostIndex ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percent changes for 12-months"@en , "Процентные изменения за 12 месяцев"@ru ;
    rdfs:comment "Percent changes for 12-months ended to the measurement date"@en , "Процентные изменения за 12 месяцев относительно даты измерения"@ru .

wf:workerCategory a rdf:Property ;
    rdfs:domain wf:IndexAggregation ;
    rdfs:range xsd:string ;
    rdfs:label "Worker category"@en , "Категория работников"@ru ;
    rdfs:comment "General category of workers"@en , "Общая категория работников"@ru .

wf:categoryNote a rdf:Property ;
    rdfs:domain wf:IndexAggregation ;
    rdfs:range xsd:string ;
    rdfs:label "Category note"@en , "Примечание к категории"@ru ;
    rdfs:comment "Note on the category of workers"@en , "Примечание к категории работников"@ru .

wf:date a rdf:Property ;
    rdfs:domain wf:IndexAggregation ;
    rdfs:range xsd:date ;
    rdfs:label "Date"@en , "Дата"@ru ;
    rdfs:comment "Time period for which the labor cost index was measured"@en , "Временной период за который проведено измерение индекса стоимости рабочей силы"@ru .

wf:totalIndex a rdf:Property ;
    rdfs:domain wf:IndexAggregation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Total index"@en , "Суммарный индекс"@ru ;
    rdfs:comment "Total employment cost index for benefits for entire worker category"@en , "Суммарный индекс стоимости рабочей силы с учетом льгот по всей категории работников"@ru .

wf:overallThreeMonthPercentChange a rdf:Property ;
    rdfs:domain wf:IndexAggregation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Overall percent changes for	3-months"@en , "Общие процентные изменения за 3 месяца"@ru ;
    rdfs:comment "Overall percentage changes for 3 months for all criteria"@en , "Общие процентные изменения за 3 месяца по всем критериям"@ru .

wf:overallTwelveMonthPercentChange a rdf:Property ;
    rdfs:domain wf:IndexAggregation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Overall percent changes for	12-months"@en , "Общие процентные изменения за 12 месяцев"@ru ;
    rdfs:comment "Overall percentage changes for 12 months for all criteria"@en , "Общие процентные изменения за 3 месяцев по всем критериям"@ru .
