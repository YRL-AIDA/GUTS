@prefix scn: <http://example.org/science#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

scn:TertiaryBranchMeasurement a rdfs:Class ;
    rdfs:label "Tertiary branch measurement"@en , "Измерение терциарного ветвления"@ru ;
    rdfs:comment "Measurement of morphological complexity of tertiary (third-order) branching in mouse mammary gland ducts"@en , "Измерение морфологической сложности терциарных (третьего порядка) ветвлений протоков молочной железы у мыши"@ru .

# ==================== Datatype Properties ====================

scn:age a rdf:Property ;
    rdfs:domain scn:TertiaryBranchMeasurement ;
    rdfs:range xsd:integer ;
    rdfs:label "Age in months"@en , "Возраст в месяцах"@ru ;
    rdfs:comment "Age of mouse in months (3 or 6)"@en , "Возраст мыши в месяцах (3 или 6)"@ru .

scn:mouse a rdf:Property ;
    rdfs:domain scn:TertiaryBranchMeasurement ;
    rdfs:range xsd:string ;
    rdfs:label "Mouse"@en , "Мышь"@ru ;
    rdfs:comment "Name or identifier of experimental mouse"@en , "Имя или идентификатор экспериментальной мыши"@ru .

scn:tertiaryBranchComplexity a rdf:Property ;
    rdfs:domain scn:TertiaryBranchMeasurement ;
    rdfs:range xsd:integer ;
    rdfs:label "Tertiary branch complexity"@en , "Сложность терциарного ветвления"@ru ;
    rdfs:comment "Dimensionless index of tertiary branch morphological complexity"@en , "Безразмерный индекс морфологической сложности терциарного ветвления"@ru .
