@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:ChainedConsumerPriceIndex a rdfs:Class ;
    rdfs:label "Chained consumer price index"@en, "Цепной индекс потребительских цен"@ru ;
    rdfs:comment "Chained consumer price index for all urban consumers: U.S. city average, by expenditure category and commodity and service group"@en, "Цепной индекс потребительских цен для всех городских потребителей: средний показатель по городам США, по категориям расходов и группам товаров и услуг"@ru .

# ==================== Datatype Properties ====================

eco:indentLevel a rdf:Property ;
    rdfs:domain eco:ChainedConsumerPriceIndex ;
    rdfs:range xsd:integer ;
    rdfs:label "Indent level"@en, "Уровень вложенности"@ru ;
    rdfs:comment "Hierarchical indentation level of the category (0–3)"@en, "Уровень иерархической вложенности категории (0–3)"@ru .

eco:group a rdf:Property ;
    rdfs:domain eco:ChainedConsumerPriceIndex ;
    rdfs:range xsd:string ;
    rdfs:label "Group"@en, "Группа"@ru ;
    rdfs:comment "Name of the category or group of expenses"@en, "Название категории или группы расходов"@ru .

eco:relativeImportance a rdf:Property ;
    rdfs:domain eco:ChainedConsumerPriceIndex ;
    rdfs:range xsd:decimal ;
    rdfs:label "Relative importance"@en, "Относительная важность"@ru ;
    rdfs:comment "Relative importance weight of the category as of 2022"@en, "Вес относительной важности категории по состоянию на 2022 год"@ru .

eco:observationMonth a rdf:Property ;
    rdfs:domain eco:ChainedConsumerPriceIndex ;
    rdfs:range xsd:gYearMonth ;
    rdfs:label "Observation month"@en, "Месяц наблюдения"@ru ;
    rdfs:comment "Month of observation in MM-YYYY format"@en, "Месяц наблюдения в формате ММ-ГГГГ"@ru .

eco:unadjustedIndex a rdf:Property ;
    rdfs:domain eco:ChainedConsumerPriceIndex ;
    rdfs:range xsd:decimal ;
    rdfs:label "Unadjusted index"@en, "Нескорректированный индекс"@ru ;
    rdfs:comment "Unadjusted сonsumer price index value for the group and month"@en, "Нескорректированное значение индекса потребительских цен для данной группы и месяца"@ru .

eco:percentChange a rdf:Property ;
    rdfs:domain eco:ChainedConsumerPriceIndex ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percent change"@en, "Процентное изменение"@ru ;
    rdfs:comment "Unadjusted percentage change over a specified time period"@en, "Нескорректированное процентное изменение за определенный временной период"@ru .
