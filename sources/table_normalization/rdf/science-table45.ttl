@prefix scn: <http://example.org/science#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

scn:TransformedClonePercentageMeasurement a rdfs:Class ;
    rdfs:label "Measurement of transformed clones"@en , "Измерение трансформированных клонов"@ru ;
    rdfs:comment "Percentage measurement of transformed mammary epithelial clones distributed across anatomical compartments (ducts and side branches) in mouse model"@en , "Процентное измерение трансформированных клонов эпителия молочной железы по анатомическим компартментам (протоки и боковые ветвления) в модели мыши"@ru .

# ==================== Datatype Properties ====================

scn:mouse a rdf:Property ;
    rdfs:domain scn:TransformedClonePercentageMeasurement ;
    rdfs:range xsd:string ;
    rdfs:label "Mouse"@en , "Мышь"@ru ;
    rdfs:comment "Name or identifier of the experimental mouse"@en , "Имя или идентификатор экспериментальной мыши"@ru .

scn:cloneType a rdf:Property ;
    rdfs:domain scn:TransformedClonePercentageMeasurement ;
    rdfs:range xsd:string ;
    rdfs:label "Clone type"@en , "Тип клона"@ru ;
    rdfs:comment "Epithelial cell type of clone"@en , "Тип эпителиальных клеток клона"@ru .

scn:duct a rdf:Property ;
    rdfs:domain scn:TransformedClonePercentageMeasurement ;
    rdfs:range xsd:decimal ;
    rdfs:label "Duct"@en , "Проток"@ru ;
    rdfs:comment "Percentage of transformed clones in the ducts"@en , "Процентное содержание трансформированных клонов в протоках"@ru .

scn:sideBranch a rdf:Property ;
    rdfs:domain scn:TransformedClonePercentageMeasurement ;
    rdfs:range xsd:decimal ;
    rdfs:label "Side branch"@en , "Боковая ветвь"@ru ;
    rdfs:comment "Percentage of transformed clones in the side branches"@en , "Процентное содержание трансформированных клонов в боковых ветвях"@ru .
