@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:ProducerPriceIndex a rdfs:Class ;
    rdfs:label "Producer price index"@en, "Индекс цен производителей"@ru ;
    rdfs:comment "Forecast data for changes in the Producer Price Index (CPI) by food category for 2022–2025"@en, "Данные прогноза изменений индекса цен производителей по продовольственным категориям за 2022–2025 годы"@ru .

# ==================== Datatype Properties ====================

eco:indexItem a rdf:Property ;
    rdfs:domain eco:ProducerPriceIndex ;
    rdfs:range xsd:string ;
    rdfs:label "Index item"@en, "Показатель индекса"@ru ;
    rdfs:comment "Descriptive name of the producer price index category"@en, "Описательное название категории индекса цен производителей"@ru .

eco:measurementCategory a rdf:Property ;
    rdfs:domain eco:ProducerPriceIndex ;
    rdfs:range xsd:string ;
    rdfs:label "Measurement category"@en, "Категория измерения"@ru ;
    rdfs:comment "A category for measuring the percentage change in a producer price index item over a specific time period"@en, "Категория измерения процентного изменения для элемента индекса цен производителей в конкретный временной период"@ru .

eco:measurementVariant a rdf:Property ;
    rdfs:domain eco:ProducerPriceIndex ;
    rdfs:range xsd:string ;
    rdfs:label "Measurement variant"@en, "Вариант измерения"@ru ;
    rdfs:comment "Measurement variant type"@en, "Тип варианта измерения"@ru .

eco:percentChange a rdf:Property ;
    rdfs:domain eco:ProducerPriceIndex ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percent change"@en, "Процентное изменение"@ru ;
    rdfs:comment "Percentage change value for producer price index item"@en, "Значение процентного изменения для элемента индекса цен производителей"@ru .
