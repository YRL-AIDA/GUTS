@prefix soc: <http://example.org/society#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

soc:FamPlanModelData a rdfs:Class ;
    rdfs:label "FamPlan model data"@en , "Данные модели FamPlan"@ru ;
    rdfs:comment "LiST input data - Family planning coverage with mitigation measures"@en , "Входные данные LiST - Охват планированием семьи с мерами по смягчению последствий"@ru .

soc:DataAggregation a rdfs:Class ;
    rdfs:label "Data aggregation"@en , "Агрегация данных"@ru ;
    rdfs:comment "An aggregated indicator related to Family Planning coverage"@en , "Агрегированный показатель, связанный с охватом планирования семьи"@ru .

# ==================== Datatype Properties ====================

soc:category a rdf:Property ;
    rdfs:domain soc:FamPlanModelData ;
    rdfs:range xsd:string ;
    rdfs:label "Method category"@en , "Категория метода"@ru ;
    rdfs:comment "The high-level category of the contraceptive method"@en , "Категория верхнего уровня для метода контрацепции"@ru .

soc:methodName a rdf:Property ;
    rdfs:domain soc:FamPlanModelData ;
    rdfs:range xsd:string ;
    rdfs:label "Method name"@en , "Название метода"@ru ;
    rdfs:comment "The specific name or description of the contraceptive method"@en , "Конкретное название или описание метода контрацепции"@ru .

soc:2019PreCOVID a rdf:Property ;
    rdfs:domain soc:FamPlanModelData ;
    rdfs:range xsd:decimal ;
    rdfs:label "2019 pre-COVID"@en , "2019 год до COVID-19"@ru ;
    rdfs:comment "Coverage percentage for this method in 2019 (pre-pandemic baseline)"@en , "Процент покрытия для данного метода в 2019 году (базовый период до пандемии)"@ru .

soc:2020WithCOVID a rdf:Property ;
    rdfs:domain soc:FamPlanModelData ;
    rdfs:range xsd:decimal ;
    rdfs:label "2020 with COVID"@en , "2020 год с COVID-19"@ru ;
    rdfs:comment "Coverage percentage for this method in 2020 (during pandemic, without mitigation)"@en , "Процент покрытия для данного метода в 2020 году (во время пандемии, без мер смягчения)"@ru .

soc:2021WithMitigation a rdf:Property ;
    rdfs:domain soc:FamPlanModelData ;
    rdfs:range xsd:decimal ;
    rdfs:label "2021 with mitigation"@en , "2021 год с мерами по смягчению последствий"@ru ;
    rdfs:comment "Coverage percentage for this method in 2021 (with mitigation measures implemented)"@en , "Процент покрытия для данного метода в 2021 году (при реализации мер смягчения)"@ru .

soc:total2019PreCOVID a rdf:Property ;
    rdfs:domain soc:DataAggregation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Total 2019 pre-COVID"@en , "Итого за 2019 год до COVID-19"@ru ;
    rdfs:comment "Total coverage percentage for this method in 2019 (pre-pandemic baseline)"@en , "Общий процент покрытия для данного метода в 2019 году (базовый период до пандемии)"@ru .

soc:total2020WithCOVID a rdf:Property ;
    rdfs:domain soc:DataAggregation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Total 2020 with COVID"@en , "Итого за 2020 год с COVID-19"@ru ;
    rdfs:comment "Total coverage percentage for this method in 2020 (during pandemic, without mitigation)"@en , "Общий процент покрытия для данного метода в 2020 году (во время пандемии, без мер смягчения)"@ru .

soc:total2021WithMitigation a rdf:Property ;
    rdfs:domain soc:DataAggregation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Total 2021 with mitigation"@en , "Итого за 2021 год с мерами по смягчению последствий"@ru ;
    rdfs:comment "Total coverage percentage for this method in 2021 (with mitigation measures implemented)"@en , "Общий процент покрытия для данного метода в 2021 году (при реализации мер смягчения)"@ru .
