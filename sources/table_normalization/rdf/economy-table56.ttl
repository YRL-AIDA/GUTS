@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:BudgetPerformanceReport a rdfs:Class ;
    rdfs:label "Budget performance report"@en, "Отчет об исполнении бюджета"@ru ;
    rdfs:comment "A budget execution report containing actual, planned, and variation financial metrics for a specific product in a specific month"@en, "Отчет об исполнении бюджета, содержащий фактические, плановые и вариационные финансовые метрики для конкретного продукта в конкретном месяце"@ru .

# ==================== Datatype Properties ====================

eco:product a rdf:Property ;
    rdfs:domain eco:BudgetPerformanceReport ;
    rdfs:range xsd:string ;
    rdfs:label "Product"@en, "Продукт"@ru ;
    rdfs:comment "The identifier or name of the product being tracked"@en, "Идентификатор или название отслеживаемого продукта"@ru .

eco:month a rdf:Property ;
    rdfs:domain eco:BudgetPerformanceReport ;
    rdfs:range xsd:string ;
    rdfs:label "Month"@en, "Месяц"@ru ;
    rdfs:comment "The month for which the financial metrics are recorded"@en, "Месяц, за который регистрируются финансовые показатели"@ru .

eco:actual a rdf:Property ;
    rdfs:domain eco:BudgetPerformanceReport ;
    rdfs:range xsd:decimal ;
    rdfs:label "Actual cost"@en, "Фактическая стоимость"@ru ;
    rdfs:comment "The actual realized financial value for the product in the given month"@en, "Фактическая реализованная финансовая стоимость продукта в данном месяце"@ru .

eco:budget a rdf:Property ;
    rdfs:domain eco:BudgetPerformanceReport ;
    rdfs:range xsd:decimal ;
    rdfs:label "Budget"@en, "Бюджет"@ru ;
    rdfs:comment "The planned or budgeted financial target for the product in the given month"@en, "Планируемый или заложенный в бюджет финансовый показатель для данного продукта в указанном месяце"@ru .

eco:variance a rdf:Property ;
    rdfs:domain eco:BudgetPerformanceReport ;
    rdfs:range xsd:decimal ;
    rdfs:label "Variance"@en, "Дисперсия"@ru ;
    rdfs:comment "The difference between Actual and Budget values (Actual - Budget)"@en, "Разница между фактическими и бюджетными значениями (Фактические - Бюджетные)"@ru .
