@prefix soc: <http://example.org/society#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

soc:BankruptcyMonitoring a rdfs:Class ;
    rdfs:label "Bankruptcy monitoring"@en , "Мониторинг банкротства"@ru ;
    rdfs:comment "Monitoring the number of individual bankruptcy cases stratified by self-employment status and time period"@en , "Мониторинг количества дел о банкротстве физических лиц с разбивкой по статусу самозанятости и временному периоду"@ru .

soc:Comparison a rdfs:Class ;
    rdfs:label "Comparison"@en , "Сравнение"@ru ;
    rdfs:comment "Calculate the percentage change for comparison to a specific time period"@en , "Расчёт процентного изменения для сравнения с определенным временным периодом"@ru .

# ==================== Object Properties ====================

soc:hasComparison a rdf:Property ;
    rdfs:domain soc:BankruptcyMonitoring ;
    rdfs:range soc:Comparison ;
    rdfs:label "Comparison"@en, "Сравнение"@ru ;
    rdfs:comment "Comparison of individual bankruptcy cases over a specific time period"@en, "Сравнение банкротств физических лиц по определенному временному периоду"@ru .

# ==================== Datatype Properties ====================

soc:year a rdf:Property ;
    rdfs:domain soc:BankruptcyMonitoring ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en , "Год"@ru ;
    rdfs:comment "Calendar year of observation"@en , "Календарный год наблюдения"@ru .

soc:quarter a rdf:Property ;
    rdfs:domain soc:BankruptcyMonitoring ;
    rdfs:range xsd:string ;
    rdfs:label "Quarter"@en , "Квартал"@ru ;
    rdfs:comment "The quarter within the year (Q1, Q2, Q3, Q4), and null for annual records"@en , "Квартал в пределах года (Q1, Q2, Q3, Q4) и null для годовых записей"@ru .

soc:totalBankruptcy a rdf:Property ;
    rdfs:domain soc:BankruptcyMonitoring ;
    rdfs:range xsd:integer ;
    rdfs:label "Total bankruptcies"@en , "Всего банкротств"@ru ;
    rdfs:comment "Total number of individual bankruptcy cases in the period"@en , "Общее количество дел о банкротстве физических лиц за период"@ru .

soc:selfEmployedCount a rdf:Property ;
    rdfs:domain soc:BankruptcyMonitoring ;
    rdfs:range xsd:integer ;
    rdfs:label "Self employed count"@en , "Количество самозанятых"@ru ;
    rdfs:comment "Number of bankruptcy cases among self-employed individuals"@en , "Количество дел о банкротстве среди самозанятых лиц"@ru .

soc:selfEmployedPercentage a rdf:Property ;
    rdfs:domain soc:BankruptcyMonitoring ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percentage of self-employed"@en , "Процент самозанятых"@ru ;
    rdfs:comment "Percentage share of self-employed bankruptcies among total bankruptcies"@en , "Процентная доля банкротств среди самозанятых от общего количества банкротств"@ru .

soc:otherIndividualCount a rdf:Property ;
    rdfs:domain soc:BankruptcyMonitoring ;
    rdfs:range xsd:integer ;
    rdfs:label "Other individual count"@en , "Количество других людей"@ru ;
    rdfs:comment "Number of bankruptcy cases among other individuals"@en , "Количество дел о банкротстве среди прочих физических лиц"@ru .

soc:otherIndividualPercentage a rdf:Property ;
    rdfs:domain soc:BankruptcyMonitoring ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percentage of other individuals"@en , "Процент других лиц"@ru ;
    rdfs:comment "Percentage share of other individuals' bankruptcies among total bankruptcies"@en , "Процентная доля банкротств среди прочих физических лиц от общего количества банкротств"@ru .

soc:year a rdf:Property ;
    rdfs:domain soc:Comparison ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en , "Год"@ru ;
    rdfs:comment "Calendar year of observation"@en , "Календарный год наблюдения"@ru .

soc:quarter a rdf:Property ;
    rdfs:domain soc:Comparison ;
    rdfs:range xsd:string ;
    rdfs:label "Quarter"@en , "Квартал"@ru ;
    rdfs:comment "The quarter within the year (Q1, Q2, Q3, Q4), and null for annual records"@en , "Квартал в пределах года (Q1, Q2, Q3, Q4) и null для годовых записей"@ru .

soc:totalBankruptcyPercentageСhange a rdf:Property ;
    rdfs:domain soc:Comparison ;
    rdfs:range xsd:integer ;
    rdfs:label "Percentage change of total bankruptcies"@en , "Процентное изменение общего количества банкротств"@ru ;
    rdfs:comment "Percentage change of total number of individual bankruptcy cases in the period"@en , "Процентное изменение общего количества дел о банкротстве физических лиц за период"@ru .

soc:selfEmployedPercentageСhange a rdf:Property ;
    rdfs:domain soc:Comparison ;
    rdfs:range xsd:integer ;
    rdfs:label "Percentage change of self employed"@en , "Процентное изменение числа самозанятых"@ru ;
    rdfs:comment "Percentage change in self-employed bankruptcies between base and target periods"@en , "Процентное изменение количества банкротств среди самозанятых между базовым и целевым периодами"@ru .

soc:otherIndividualsPercentageСhange a rdf:Property ;
    rdfs:domain soc:Comparison ;
    rdfs:range xsd:integer ;
    rdfs:label "Percentage change of other individuals"@en , "Процентное изменение показателей других лиц"@ru ;
    rdfs:comment "Percentage change in other individuals' bankruptcies between base and target periods"@en , "Процентное изменение количества банкротств среди прочих физических лиц между базовым и целевым периодами"@ru .
