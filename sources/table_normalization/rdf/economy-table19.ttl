@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:BankruptcyObservation a rdfs:Class ;
    rdfs:label "Bankruptcy observation"@en, "Наблюдение за банкротствами"@ru ;
    rdfs:comment "Bankruptcy rates per 10,000 adults, by location, England and Wales, 2011 to 2021"@en, "Показатели банкротств на 10 000 взрослых по регионам, Англия и Уэльс, 2011–2021 гг."@ru .

# ==================== Datatype Properties ====================

eco:year a rdf:Property ;
    rdfs:domain eco:BankruptcyObservation ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "Calendar year of observation"@en, "Календарный год наблюдения"@ru .

eco:code a rdf:Property ;
    rdfs:domain eco:BankruptcyObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Code"@en, "Код"@ru ;
    rdfs:comment "The geographic code of location"@en, "Географический код местоположения"@ru .

eco:location a rdf:Property ;
    rdfs:domain eco:BankruptcyObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Location"@en, "Местоположение"@ru ;
    rdfs:comment "The name of the geographic are"@en, "Название географической области"@ru .

eco:geography a rdf:Property ;
    rdfs:domain eco:BankruptcyObservation ;
    rdfs:range xsd:string ;
    rdfs:label "Geography"@en, "География"@ru ;
    rdfs:comment "The type of geographic area"@en, "Тип географической области"@ru .

eco:bankruptcyRate a rdf:Property ;
    rdfs:domain eco:BankruptcyObservation ;
    rdfs:range xsd:decimal ;
    rdfs:label "Bankruptcy rate"@en, "Уровень банкротств"@ru ;
    rdfs:comment "The rate of bankruptcy over a given period of time as a percentage"@en, "Уровень банкротств за определенный период времени в процентах"@ru .
