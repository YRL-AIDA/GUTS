@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:SalesProductivity a rdfs:Class ;
    rdfs:label "Sales productivity"@en, "Производительность продаж"@ru ;
    rdfs:comment "Sales productivity (calls, units, amount) for a specific employee in a specific city"@en, "Производительность продаж (звонки, единицы, сумма) для конкретного сотрудника в определенном городе"@ru .

eco:OverallSalesPerformance a rdfs:Class ;
    rdfs:label "Overall sales performance"@en, "Общая производительность продаж"@ru ;
    rdfs:comment "Overall sales performance for all employees across all cities"@en, "Общая производительность продаж для всех сотрудников по всем городам"@ru .

# ==================== Datatype Properties ====================

eco:city a rdf:Property ;
    rdfs:domain eco:SalesProductivity ;
    rdfs:range xsd:string ;
    rdfs:label "City"@en, "Город"@ru ;
    rdfs:comment "The city where the sales activity took place"@en, "Город, где осуществлялась торговая деятельность"@ru .

eco:employeeName a rdf:Property ;
    rdfs:domain eco:SalesProductivity ;
    rdfs:range xsd:string ;
    rdfs:label "Employee name"@en, "Имя сотрудника"@ru ;
    rdfs:comment "The name of the employee making the sale"@en, "Имя сотрудника, осуществляющего продажу"@ru .

eco:calls a rdf:Property ;
    rdfs:domain eco:SalesProductivity ;
    rdfs:range xsd:integer ;
    rdfs:label "Number of calls"@en, "Количество звонков"@ru ;
    rdfs:comment "The total number of calls made by the employee in the given city"@en, "Общее количество звонков, совершенных сотрудником в данном городе"@ru .

eco:units a rdf:Property ;
    rdfs:domain eco:SalesProductivity ;
    rdfs:range xsd:integer ;
    rdfs:label "Number of units"@en, "Количество единиц"@ru ;
    rdfs:comment "The total number of item units sold by the employee in the given city"@en, "Общее количество единиц товара, проданных сотрудником в данном городе"@ru .

eco:monetaryValue a rdf:Property ;
    rdfs:domain eco:SalesProductivity ;
    rdfs:range xsd:decimal ;
    rdfs:label "Monetary value"@en, "Денежная стоимость"@ru ;
    rdfs:comment "The total monetary value of sales in US dollars for the employee in the given city"@en, "Общая денежная стоимость продаж в долларах США для сотрудника в данном городе"@ru .

eco:totalCalls a rdf:Property ;
    rdfs:domain eco:OverallSalesPerformance ;
    rdfs:range xsd:integer ;
    rdfs:label "Total number of calls"@en, "Общее количество звонков"@ru ;
    rdfs:comment "Total number of calls made by all employees in all cities"@en, "Общее количество звонков, совершенных всеми сотрудниками во всех городах"@ru .

eco:totalUnits a rdf:Property ;
    rdfs:domain eco:OverallSalesPerformance ;
    rdfs:range xsd:integer ;
    rdfs:label "Total number of units"@en, "Общее количество единиц"@ru ;
    rdfs:comment "Total number of units sold by all employees in all cities"@en, "Общее количество единиц товара, проданных всеми сотрудниками во всех городах"@ru .

eco:totalMonetaryValue a rdf:Property ;
    rdfs:domain eco:OverallSalesPerformance ;
    rdfs:range xsd:decimal ;
    rdfs:label "Total monetary value"@en, "Общая денежная стоимость"@ru ;
    rdfs:comment "The total monetary value of sales in US dollars for all employees in all cities"@en, "Общая денежная стоимость продаж в долларах США для всех сотрудников во всех городах"@ru .
