@prefix emp: <http://example.org/employment#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

emp:EmploymentStatistics a rdfs:Class ;
    rdfs:label "Employment statistics"@en, "Статистика занятости"@ru ;
    rdfs:comment "Annual averages of persons at work in nonagricultural industries by age, sex, race, Hispanic or Latino ethnicity, marital status, and usual full- or part-time status	"@en, "Среднегодовое количество занятых в несельскохозяйственных отраслях по возрасту, полу, расе, принадлежности к латиноамериканской этнической группе, семейному положению и обычному статусу занятости (полная или неполная занятость)"@ru .

emp:AverageHoursStatistics a rdfs:Class ;
    rdfs:label "Average hours statistics"@en, "Статистика среднего показателя часов"@ru ;
    rdfs:comment "Statistics on average hours worked for a characteristic"@en, "Статистические данные по средним показателям часов работы для конкретной характеристики"@ru .

# ==================== Datatype Properties ====================

emp:year a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "The calendar year for which the statistic is reported"@en, "Календарный год, за который приводятся статистические данные"@ru .

emp:characteristicType a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Characteristic type"@en, "Тип характеристики"@ru ;
    rdfs:comment "Type of demographic characteristic (gender, age, race, ethnicity, marital status, and employment status)"@en, "Тип демографической характеристики (пол, возраст, раса, этническая принадлежность, семейное положение и статус занятости)"@ru .

emp:characteristicValue a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Characteristic value"@en, "Значение характеристики"@ru ;
    rdfs:comment "The specific value of the characteristic"@en, "Конкретное значение характеристики"@ru .

emp:hoursCategory a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Hours category"@en, "Категория часов"@ru ;
    rdfs:comment "The weekly hours category"@en, "Категория еженедельных часов"@ru .

emp:reasonCategory a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Reason category"@en, "Категория причины"@ru ;
    rdfs:comment "The reason for working less than 35 hours"@en, "Причина работы менее 35 часов"@ru .

emp:status a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Status"@en, "Статус"@ru ;
    rdfs:comment "The usual work status for noneconomic reasons"@en, "Обычный статус занятости для неэкономических причин"@ru .

emp:annualPersonAverages a rdf:Property ;
    rdfs:domain emp:EmploymentStatistics ;
    rdfs:range xsd:integer ;
    rdfs:label "Annual averages of persons"@en, "Среднегодовое количество занятых"@ru ;
    rdfs:comment "Average annual number of employed people for a specific demographic characteristic"@en, "Среднегодовое количество занятых для конкретной демографической характеристики"@ru .

emp:year a rdf:Property ;
    rdfs:domain emp:AverageHoursStatistics ;
    rdfs:range xsd:gYear ;
    rdfs:label "Year"@en, "Год"@ru ;
    rdfs:comment "The calendar year for which the statistic is reported"@en, "Календарный год, за который приводятся статистические данные"@ru .

emp:characteristicType a rdf:Property ;
    rdfs:domain emp:AverageHoursStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Characteristic type"@en, "Тип характеристики"@ru ;
    rdfs:comment "Type of demographic characteristic (gender, age, race, ethnicity, marital status, and employment status)"@en, "Тип демографической характеристики (пол, возраст, раса, этническая принадлежность, семейное положение и статус занятости)"@ru .

emp:characteristicValue a rdf:Property ;
    rdfs:domain emp:AverageHoursStatistics ;
    rdfs:range xsd:string ;
    rdfs:label "Characteristic value"@en, "Значение характеристики"@ru ;
    rdfs:comment "The specific value of the characteristic"@en, "Конкретное значение характеристики"@ru .

emp:averageHours a rdf:Property ;
    rdfs:domain emp:AverageHoursStatistics ;
    rdfs:range xsd:decimal ;
    rdfs:label "Average hours"@en, "Среднее количество часов"@ru ;
    rdfs:comment "Average hours, total at work"@en, "Среднее количество рабочих часов, общее время работы"@ru .

emp:fullTimeAverageHours a rdf:Property ;
    rdfs:domain emp:AverageHoursStatistics ;
    rdfs:range xsd:decimal ;
    rdfs:label "Full time average hours"@en, "Среднее количество часов полный рабочий день"@ru ;
    rdfs:comment "Average hours, persons who usually work full time"@en, "Среднее количество рабочих часов, для лиц, обычно работающих полный рабочий день"@ru .
