@prefix eco: <http://example.org/economy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

eco:MonthlyRevenueReport a rdfs:Class ;
    rdfs:label "Monthly revenue report"@en, "Отчет о ежемесячной выручке"@ru ;
    rdfs:comment "Monthly revenue report by customers or employees"@en, "Ежемесячный отчет о доходах от клиентов или сотрудников"@ru .

# ==================== Datatype Properties ====================

eco:accountNumber a rdf:Property ;
    rdfs:domain eco:MonthlyRevenueReport ;
    rdfs:range xsd:integer ;
    rdfs:label "Account number"@en, "Номер счета"@ru ;
    rdfs:comment "Unique numeric identifier of the account"@en, "Уникальный числовой идентификатор счета"@ru .

eco:fullName a rdf:Property ;
    rdfs:domain eco:MonthlyRevenueReport ;
    rdfs:range xsd:string ;
    rdfs:label "Full name"@en, "Полное имя"@ru ;
    rdfs:comment "Full name of the customer or employee"@en, "Полное имя клиента или сотрудника"@ru .

eco:month a rdf:Property ;
    rdfs:domain eco:MonthlyRevenueReport ;
    rdfs:range xsd:string ;
    rdfs:label "Month"@en, "Месяц"@ru ;
    rdfs:comment "Calendar month abbreviation"@en, "Аббревиатура календарного месяца"@ru .

eco:trend a rdf:Property ;
    rdfs:domain eco:MonthlyRevenueReport ;
    rdfs:range xsd:string ;
    rdfs:label "Trend"@en, "Тренд"@ru ;
    rdfs:comment "Direction indicator of revenue change compared to previous period"@en, "Индикатор направления изменения выручки по сравнению с предыдущим периодом"@ru .

eco:revenue a rdf:Property ;
    rdfs:domain eco:MonthlyRevenueReport ;
    rdfs:range xsd:decimal ;
    rdfs:label "Revenue"@en, "Выручка"@ru ;
    rdfs:comment "Revenue amount in currency units for the account in the specified month"@en, "Сумма выручки в денежных единицах для счета в указанном месяце"@ru .
