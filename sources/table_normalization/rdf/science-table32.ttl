@prefix scn: <http://example.org/science#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==================== Classes ====================

scn:InterductalSegmentMeasurement a rdfs:Class ;
    rdfs:label "Interductal segment measurement"@en , "Измерение межпротокового сегмента"@ru ;
    rdfs:comment "Measurement of interductal segment length in mouse mammary gland"@en , "Измерение длины интердуктального сегмента молочной железы у мыши"@ru .

# ==================== Datatype Properties ====================

scn:age a rdf:Property ;
    rdfs:domain scn:InterductalSegmentMeasurement ;
    rdfs:range xsd:integer ;
    rdfs:label "Age in months"@en , "Возраст в месяцах"@ru ;
    rdfs:comment "Age of mouse in months (3 or 6)"@en , "Возраст мыши в месяцах (3 или 6)"@ru .

scn:mouse a rdf:Property ;
    rdfs:domain scn:InterductalSegmentMeasurement ;
    rdfs:range xsd:string ;
    rdfs:label "Mouse"@en , "Мышь"@ru ;
    rdfs:comment "Name or identifier of experimental mouse"@en , "Имя или идентификатор экспериментальной мыши"@ru .

scn:interductalSegmentLength a rdf:Property ;
    rdfs:domain scn:InterductalSegmentMeasurement ;
    rdfs:range xsd:integer ;
    rdfs:label "Interductal segment length"@en , "Длина межпротокового сегмента"@ru ;
    rdfs:comment "Length of interductal segment in micrometers (µm)"@en , "Длина интердуктального сегмента в микрометрах (мкм)"@ru .
